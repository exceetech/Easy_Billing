<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="12dp"
    android:background="@drawable/bg_imp_card"
    android:padding="14dp">

    <!-- Header: sync dot + invoice no. + date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:id="@+id/viewSyncDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_imp_dot"
            android:backgroundTint="#639922" />

        <TextView
            android:id="@+id/tvInvoiceNumber"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="INV-001"
            android:textColor="#1A1A18"
            android:textSize="16sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvInvoiceDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12 Apr 2026"
            android:textColor="#6E6A60"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Value + ITC eligibility badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvInvoiceValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹50,000"
                android:textColor="#1A1A18"
                android:textSize="22sp"
                android:textStyle="bold"
                android:singleLine="true" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="Taxable value"
                android:textColor="#6E6A60"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvItcEligibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inputs · ITC"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#27500A"
            android:background="@drawable/bg_imp_badge"
            android:backgroundTint="#EAF3DE"
            android:paddingHorizontal="9dp"
            android:paddingVertical="4dp" />
    </LinearLayout>

    <!-- Tax breakdown: IGST | Cess | ITC availed -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="13dp"
        android:paddingTop="12dp"
        android:background="@drawable/bg_imp_card_divider">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:id="@+id/tvIgst"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="₹9,000" android:textSize="13sp" android:textStyle="bold" android:textColor="#185FA5"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="IGST" android:textSize="10sp" android:textColor="#6E6A60"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="18dp">
            <TextView android:id="@+id/tvCess"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="₹0" android:textSize="13sp" android:textStyle="bold" android:textColor="#1A1A18"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Cess" android:textSize="10sp" android:textColor="#6E6A60"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">
            <TextView android:id="@+id/tvItcAvailed"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="₹9,000" android:textSize="13sp" android:textStyle="bold" android:textColor="#0F6E56"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ITC availed" android:textSize="10sp" android:textColor="#6E6A60"/>
        </LinearLayout>
    </LinearLayout>

    <!-- POS + rate footnote -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="11dp">
        <ImageView android:layout_width="13dp" android:layout_height="13dp"
            android:layout_marginEnd="5dp"
            android:src="@drawable/ic_location" app:tint="#6B7280" android:contentDescription="@null"/>
        <TextView
            android:id="@+id/tvPlaceOfSupply"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="POS 97 · Other Territory · 18%"
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
