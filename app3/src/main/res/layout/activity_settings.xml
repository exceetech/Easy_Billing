<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F0E6">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        android:elevation="0dp"
        app:title=""
        app:titleTextColor="#1A1A18"
        app:navigationIconTint="#1A1A18" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="20dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#1A1A18"
                android:textSize="21sp"
                android:textStyle="bold"
                android:accessibilityHeading="true"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="6dp"
                android:text="Manage your store &amp; app"
                android:textColor="#6E6A60"
                android:textSize="12sp"/>

            <!-- ===================== STORE ===================== -->
            <TextView style="@style/SettingsSection" android:text="STORE"/>

            <LinearLayout style="@style/SettingsCard">

                <LinearLayout android:id="@+id/btnStoreSettings" style="@style/SettingsRow">
                    <ImageView style="@style/SettingsIcon" android:backgroundTint="#E6F1FB"
                        android:src="@drawable/ic_set_store" app:tint="#185FA5"/>
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/store_information"/>
                        <TextView style="@style/SettingsRowSub" android:text="Name, address, contact"/>
                    </LinearLayout>
                    <ImageView style="@style/SettingsChevron"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/btnLocalization" style="@style/SettingsRow">
                    <ImageView style="@style/SettingsIcon" android:backgroundTint="#EEEDFE"
                        android:src="@drawable/ic_set_languages" app:tint="#534AB7"/>
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/localization_settings"/>
                        <TextView style="@style/SettingsRowSub" android:text="Language, currency, format"/>
                    </LinearLayout>
                    <ImageView style="@style/SettingsChevron"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ===================== BILLING ===================== -->
            <TextView style="@style/SettingsSection" android:text="BILLING"/>

            <LinearLayout style="@style/SettingsCard">

                <LinearLayout android:id="@+id/btnBillingSettings" style="@style/SettingsRow">
                    <ImageView style="@style/SettingsIcon" android:backgroundTint="#EAF3DE"
                        android:src="@drawable/ic_set_receipt" app:tint="#0F6E56"/>
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/billing_settings"/>
                        <TextView style="@style/SettingsRowSub" android:text="GST, tax rates, defaults"/>
                    </LinearLayout>
                    <ImageView style="@style/SettingsChevron"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/btnInvoiceDesign" style="@style/SettingsRow">
                    <ImageView style="@style/SettingsIcon" android:backgroundTint="#FAEEDA"
                        android:src="@drawable/ic_set_file_text" app:tint="#854F0B"/>
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/invoice_design"/>
                        <TextView style="@style/SettingsRowSub" android:text="Template &amp; branding"/>
                    </LinearLayout>
                    <ImageView style="@style/SettingsChevron"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ===================== DATA ===================== -->
            <TextView style="@style/SettingsSection" android:text="DATA"/>

            <LinearLayout style="@style/SettingsCard">

                <LinearLayout android:id="@+id/btnDataManagement" style="@style/SettingsRow">
                    <ImageView style="@style/SettingsIcon" android:backgroundTint="#FCEBEB"
                        android:src="@drawable/ic_set_shield" app:tint="#A32D2D"/>
                    <LinearLayout style="@style/SettingsRowText">
                        <TextView style="@style/SettingsRowTitle" android:text="@string/data_security_management"/>
                        <TextView style="@style/SettingsRowSub" android:text="Backup, workspace, reset"/>
                    </LinearLayout>
                    <ImageView style="@style/SettingsChevron"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="ExPOS"
                android:textColor="#C9C3B4"
                android:textSize="11sp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
