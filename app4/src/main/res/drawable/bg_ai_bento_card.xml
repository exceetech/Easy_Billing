<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#10000000"> <!-- Subtle dark ripple -->
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <corners android:radius="24dp"/>
            <solid android:color="@android:color/white"/>
        </shape>
    </item>
    <item>
        <layer-list>
            <!-- Main glass body -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="24dp"/>
                    <solid android:color="#FDFDFD"/>
                    <stroke android:width="1dp" android:color="#F1F1F1"/>
                </shape>
            </item>
            <!-- Inner reflection for depth -->
            <item android:bottom="4dp" android:left="1dp" android:right="1dp" android:top="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="24dp"/>
                    <gradient
                        android:angle="90"
                        android:endColor="#02000000"
                        android:startColor="#00000000"/>
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
