<?xml version="1.0" encoding="utf-8"?>
<!--
    Logo halo on the dark card — soft champagne radial wash
    around a cream-thin ring. Three concentric layers so the
    logo feels "photographed" rather than stamped.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="200"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#33D4A574"
                android:endColor="#00D4A574"/>
        </shape>
    </item>
    <item
        android:left="8dp"
        android:right="8dp"
        android:top="8dp"
        android:bottom="8dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="160"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#22E8DCC4"
                android:endColor="#00E8DCC4"/>
        </shape>
    </item>
    <item
        android:left="20dp"
        android:right="20dp"
        android:top="20dp"
        android:bottom="20dp">
        <shape android:shape="oval">
            <solid android:color="#0DFFFFFF"/>
            <stroke
                android:width="1dp"
                android:color="#22E8DCC4"/>
        </shape>
    </item>
</layer-list>
