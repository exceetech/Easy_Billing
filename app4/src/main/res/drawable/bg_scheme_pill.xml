<!--
    Pill used inside the dark hero card to flag the GST scheme
    ("NORMAL GST SCHEME" / "COMPOSITION SCHEME"). Translucent
    emerald-on-dark, sized to feel like a luxury watch dial label.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <corners android:radius="999dp"/>
    <solid android:color="#0F2A1F"/>
    <stroke android:width="1dp" android:color="#22C55E"/>
</shape>
