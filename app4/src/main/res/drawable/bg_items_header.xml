<?xml version="1.0" encoding="utf-8"?>
<!--
    Column-header strip above the items list. Pale neutral panel
    with rounded top corners only — meant to look like the lid of
    the items table card.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <corners android:topLeftRadius="18dp" android:topRightRadius="18dp"/>
    <solid android:color="#F3F4F6"/>
    <stroke android:width="1dp" android:color="#E5E7EB"/>
</shape>
