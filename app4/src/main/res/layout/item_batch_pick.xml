<?xml version="1.0" encoding="utf-8"?>
<!--
    One row in the supplier-return batch picker.

    Plain EditText (not TextInputEditText) is intentional — wrapping
    each row's input in a TextInputLayout inside a RecyclerView inside
    a Dialog was eating focus / IME interactions on some devices.
    The plain EditText with a rounded background drawable gives the
    same look without the focus pitfall.

    IDs match what BatchPickerAdapter binds:
      tvBatchInvoice  — invoice number (or "Stock entry #id" fallback)
      tvBatchSupplier — supplier display name
      tvBatchMeta     — purchase date · unit cost
      tvBatchRemain   — qty still remaining for this batch
      etBatchQty      — user-entered return qty for this row
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBatchInvoice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBatchSupplier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="#D4A574"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvBatchMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="#B0FFFFFF"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvBatchRemain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="@color/white"
                android:alpha="0.85"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etBatchQty"
            android:layout_width="90dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_batch_qty_input"
            android:gravity="center"
            android:hint="Qty"
            android:textColorHint="#80FFFFFF"
            android:inputType="numberDecimal"
            android:maxLines="1"
            android:imeOptions="actionDone"
            android:padding="8dp"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="10dp"
        android:background="#33FFFFFF" />

</LinearLayout>
