<?xml version="1.0" encoding="utf-8"?>

<!--
  Top Products — Sales design language with a SHARE donut.
  cream page > white card > header (+ sort chip) · donut (center total) ·
  legend · product breakdown list.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1EEE9">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardPreventCornerOverlap="true"
        app:cardBackgroundColor="#FFFFFF">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="22dp"
                    android:paddingBottom="110dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Top products"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#14161A"/>

                        <TextView
                            android:id="@+id/tvSortChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fast moving ▾"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#1B3A8A"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"/>
                    </LinearLayout>

                    <!-- Donut + center total -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginBottom="14dp">

                        <com.github.mikephil.charting.charts.PieChart
                            android:id="@+id/pieChart"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvCenterVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#14161A"/>

                            <TextView
                                android:id="@+id/tvCenterLbl"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="total"
                                android:textSize="11sp"
                                android:textColor="#9AA0A8"/>
                        </LinearLayout>
                    </FrameLayout>

                    <!-- Legend (filled in code, 2 columns) -->
                    <LinearLayout
                        android:id="@+id/llLegend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product breakdown"
                        android:textSize="13sp"
                        android:textColor="#6B7280"
                        android:layout_marginBottom="2dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvProducts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>

                    <TextView
                        android:id="@+id/tvEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No products found"
                        android:textSize="14sp"
                        android:textColor="#9CA3AF"
                        android:gravity="center"
                        android:paddingVertical="24dp"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- Soft top-edge fade (matches Sales) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_gravity="top"
                android:background="@drawable/bg_scroll_top_fade"/>

        </FrameLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
