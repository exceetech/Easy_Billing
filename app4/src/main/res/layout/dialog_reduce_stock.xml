<?xml version="1.0" encoding="utf-8"?>
<!--
    Reduce Stock — single-screen flow.

    Reason selection swaps the visible input region:
      • Purchase Return → inline batch list (rvBatches). Total is the
        sum of per-batch quantities, derived live.
      • Scrap / Damage  → single quantity input (etReduceQty).

    The credit-account section only shows for Purchase Return, since
    scrap doesn't affect what's owed to a supplier.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    android:layout_margin="16dp">

    <ScrollView

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:fillViewport="true"

        android:overScrollMode="never">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp"
            android:background="@drawable/bg_dialog_gradient">

            <!-- ── HEADER ──────────────────────────────── -->
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:layout_marginBottom="10dp"
                android:src="@drawable/ic_remove"
                app:tint="#F59E0B"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Reduce Stock"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvCurrentStockLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Available: 0"
                android:textColor="#B0FFFFFF"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"/>

            <!-- ── REASON ──────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reason"
                android:textColor="#80FFFFFF"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <RadioGroup
                android:id="@+id/rgReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rbReturn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Return to Supplier"
                    android:textColor="@color/white"
                    android:buttonTint="@color/white"
                    android:checked="true"/>

                <RadioButton
                    android:id="@+id/rbScrap"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Scrap / Damage"
                    android:textColor="@color/white"
                    android:buttonTint="@color/white"/>
            </RadioGroup>

            <!-- ── SCRAP SECTION (visible for Scrap only) ── -->
            <LinearLayout
                android:id="@+id/scrapSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="14dp">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Quantity to reduce"
                    android:textColorHint="#80FFFFFF"
                    app:boxStrokeColor="@color/white"
                    app:hintTextColor="@color/white">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etReduceQty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- ── RETURN SECTION (visible for Return only) ── -->
            <LinearLayout
                android:id="@+id/returnSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pick batches and per-batch quantity"
                    android:textColor="#B0FFFFFF"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/tvBatchesEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="No purchase batches available"
                    android:textColor="#B0FFFFFF"
                    android:textSize="13sp"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvBatches"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginTop="10dp"
                    android:overScrollMode="never"
                    android:descendantFocusability="afterDescendants"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:id="@+id/tvTotalLabel"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Total to return"
                        android:textColor="#B0FFFFFF"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tvBatchRunning"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── CREDIT (Return only) ──────────────────── -->
            <LinearLayout
                android:id="@+id/layoutCreditReturn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Credit account"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>

                <CheckBox
                    android:id="@+id/cbAdjustCredit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reduce debt from account"
                    android:textColor="@color/white"
                    android:buttonTint="@color/white"/>

                <TextView
                    android:id="@+id/tvReturnAccountName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No account selected"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- ── BUTTONS ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReduceCancel"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancel"
                    android:textColor="@color/white"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReduceConfirm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reduce"
                    android:backgroundTint="#F59E0B"
                    android:textColor="@color/white"
                    app:cornerRadius="12dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</com.google.android.material.card.MaterialCardView>
