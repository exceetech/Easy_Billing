<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1EEE9">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        app:title="Analytics Dashboard"
        app:titleCentered="true"
        android:elevation="0dp"
        android:background="@android:color/transparent"
        app:titleTextColor="@color/textPrimary"
        app:navigationIconTint="@color/textPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipDateFilter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        app:singleSelection="true"
        app:chipSpacingHorizontal="8dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipToday"
            android:text="Today"
            android:checked="true"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            app:chipBackgroundColor="@color/chip_bg_soft_selector"
            app:chipStrokeColor="@color/chip_stroke_soft_selector"
            app:chipStrokeWidth="1.5dp"
            app:chipCornerRadius="8dp"
            app:chipIcon="@drawable/ic_chip_dot"
            app:chipIconSize="8dp"
            app:chipIconTint="@color/chip_dot_tint_selector"
            app:chipStartPadding="10dp"
            app:chipEndPadding="10dp"
            app:iconStartPadding="0dp"
            app:iconEndPadding="4dp"
            app:checkedIconVisible="false"
            app:chipMinTouchTargetSize="0dp"
            android:textColor="@color/chip_text_soft_selector"
            android:textSize="13sp"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipWeek"
            android:text="Week"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            app:chipBackgroundColor="@color/chip_bg_soft_selector"
            app:chipStrokeColor="@color/chip_stroke_soft_selector"
            app:chipStrokeWidth="1.5dp"
            app:chipCornerRadius="8dp"
            app:chipIcon="@drawable/ic_chip_dot"
            app:chipIconSize="8dp"
            app:chipIconTint="@color/chip_dot_tint_selector"
            app:chipStartPadding="10dp"
            app:chipEndPadding="10dp"
            app:iconStartPadding="0dp"
            app:iconEndPadding="4dp"
            app:checkedIconVisible="false"
            app:chipMinTouchTargetSize="0dp"
            android:textColor="@color/chip_text_soft_selector"
            android:textSize="13sp"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipMonth"
            android:text="Month"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            app:chipBackgroundColor="@color/chip_bg_soft_selector"
            app:chipStrokeColor="@color/chip_stroke_soft_selector"
            app:chipStrokeWidth="1.5dp"
            app:chipCornerRadius="8dp"
            app:chipIcon="@drawable/ic_chip_dot"
            app:chipIconSize="8dp"
            app:chipIconTint="@color/chip_dot_tint_selector"
            app:chipStartPadding="10dp"
            app:chipEndPadding="10dp"
            app:iconStartPadding="0dp"
            app:iconEndPadding="4dp"
            app:checkedIconVisible="false"
            app:chipMinTouchTargetSize="0dp"
            android:textColor="@color/chip_text_soft_selector"
            android:textSize="13sp"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipYear"
            android:text="Year"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            app:chipBackgroundColor="@color/chip_bg_soft_selector"
            app:chipStrokeColor="@color/chip_stroke_soft_selector"
            app:chipStrokeWidth="1.5dp"
            app:chipCornerRadius="8dp"
            app:chipIcon="@drawable/ic_chip_dot"
            app:chipIconSize="8dp"
            app:chipIconTint="@color/chip_dot_tint_selector"
            app:chipStartPadding="10dp"
            app:chipEndPadding="10dp"
            app:iconStartPadding="0dp"
            app:iconEndPadding="4dp"
            app:checkedIconVisible="false"
            app:chipMinTouchTargetSize="0dp"
            android:textColor="@color/chip_text_soft_selector"
            android:textSize="13sp"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipCustom"
            android:text="Custom"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            app:chipBackgroundColor="@color/chip_bg_soft_selector"
            app:chipStrokeColor="@color/chip_stroke_soft_selector"
            app:chipStrokeWidth="1.5dp"
            app:chipCornerRadius="8dp"
            app:chipIcon="@drawable/ic_chip_dot"
            app:chipIconSize="8dp"
            app:chipIconTint="@color/chip_dot_tint_selector"
            app:chipStartPadding="10dp"
            app:chipEndPadding="10dp"
            app:iconStartPadding="0dp"
            app:iconEndPadding="4dp"
            app:checkedIconVisible="false"
            app:chipMinTouchTargetSize="0dp"
            android:textColor="@color/chip_text_soft_selector"
            android:textSize="13sp"/>

    </com.google.android.material.chip.ChipGroup>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:background="@drawable/bg_tab_card"
        app:tabIndicatorColor="#1B3A8A"
        app:tabIndicatorHeight="44dp"
        app:tabIndicator="@drawable/bg_tab_indicator"
        app:tabIndicatorFullWidth="true"
        app:tabIndicatorGravity="center"
        app:tabPaddingTop="0dp"
        app:tabPaddingBottom="0dp"
        app:tabPaddingStart="6dp"
        app:tabPaddingEnd="6dp"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabTextColor="@color/textHint"
        app:tabRippleColor="#0D1B3A8A"
        app:tabMode="fixed"
        app:tabTextAppearance="@style/TabTextAppearance"
        app:layout_constraintTop_toBottomOf="@id/chipDateFilter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/tabDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tabDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSendReport"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="Send Report to Email"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_send_btn_gradient"
        app:backgroundTint="@null"
        app:icon="@drawable/ic_send_report"
        app:iconGravity="end"
        app:iconTint="@color/white"
        app:iconPadding="8dp"
        app:cornerRadius="16dp"
        app:elevation="8dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
