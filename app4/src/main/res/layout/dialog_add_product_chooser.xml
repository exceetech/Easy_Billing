<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/add_edit_product_title"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="@string/add_edit_product_subtitle"
            android:textColor="#6B7280"
            android:textSize="13sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPurchasedProduct"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="22dp"
            android:text="@string/add_purchased_product"
            android:textAllCaps="false"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_inventory"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNonPurchasedProduct"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:text="@string/add_non_purchased_product"
            android:textAllCaps="false"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_addproduct"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManageProducts"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:text="@string/manage_products"
            android:textAllCaps="false"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_settings"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChooserCancel"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="14dp"
            android:text="@string/cancel"
            android:textAllCaps="false"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
