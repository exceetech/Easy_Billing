<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_dialog_card"
    android:paddingHorizontal="26dp"
    android:paddingTop="28dp"
    android:paddingBottom="22dp">

    <FrameLayout
        android:layout_width="66dp"
        android:layout_height="66dp"
        android:background="@drawable/bg_success_circle">
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_lc_check"
            app:tint="#0F6E56"
            android:contentDescription="@null"/>
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:text="ACCOUNT CREATED"
        android:textColor="#B8895A"
        android:textSize="10sp"
        android:letterSpacing="0.14"
        android:fontFamily="@font/googlesans_semibold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="You're all set"
        android:textColor="#1A1A18"
        android:textSize="20sp"
        android:fontFamily="serif"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/tvDialogMsg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:gravity="center"
        android:text="We've sent a verification code (OTP) to your email."
        android:textColor="#6E6A60"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_login_cta_green"
        app:backgroundTint="@null"
        android:text="Continue"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textAllCaps="false"
        android:fontFamily="@font/googlesans_semibold"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_cta_arrow"
        app:iconGravity="textEnd"
        app:iconTint="#FFFFFF"/>

</LinearLayout>
