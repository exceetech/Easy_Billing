<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_champagne"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <!-- ============ CENTERED GLASS CARD ============ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mainContainerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_marginVertical="24dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#94FFFFFF"
        app:strokeColor="#CCFFFFFF"
        app:strokeWidth="1dp"
        app:layout_constraintWidth_max="640dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- ===== LEFT: BRAND ===== -->
            <LinearLayout
                android:id="@+id/brandingPane"
                android:transitionName="shared_branding_pane"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.86"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:paddingStart="26dp"
                android:paddingEnd="22dp"
                android:paddingVertical="28dp">

                <!-- hidden logo (kept for shared-element + entrance) -->
                <ImageView
                    android:id="@+id/brandLogo"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:contentDescription="@null"/>
                <ImageView
                    android:id="@+id/imgIllustration"
                    android:transitionName="shared_image_pane"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:contentDescription="@null"/>

                <LinearLayout
                    android:id="@+id/brandTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ex"
                        android:textColor="#1A1A18"
                        android:textSize="30sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="POS"
                        android:textColor="#B8895A"
                        android:textSize="30sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/brandTagline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="POINT OF SALE"
                    android:textColor="#9A8F79"
                    android:textSize="10sp"
                    android:letterSpacing="0.18"
                    android:fontFamily="@font/googlesans_semibold"/>

                <LinearLayout
                    android:id="@+id/brandFeatures"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="22dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_feat_receipt"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="GST billing"
                            android:textColor="#3A3733"
                            android:textSize="13sp"
                            android:fontFamily="@font/googlesans_medium"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="15dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_feat_package"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="Live inventory"
                            android:textColor="#3A3733"
                            android:textSize="13sp"
                            android:fontFamily="@font/googlesans_medium"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="15dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_feat_chart"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="Business analytics"
                            android:textColor="#3A3733"
                            android:textSize="13sp"
                            android:fontFamily="@font/googlesans_medium"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="22dp"
                android:background="#E6DDCB"/>

            <!-- ===== RIGHT: FORM ===== -->
            <LinearLayout
                android:id="@+id/loginContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.14"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingEnd="26dp"
                android:paddingVertical="26dp">

                <!-- Tabs (loginHeader) -->
                <LinearLayout
                    android:id="@+id/loginHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_login_tab_track"
                    android:padding="3dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingVertical="8dp"
                        android:text="Login"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="@font/googlesans_semibold"
                        android:background="@drawable/bg_login_tab_active"/>
                    <TextView
                        android:id="@+id/tvRegister"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingVertical="8dp"
                        android:text="Sign up"
                        android:textColor="#8C8576"
                        android:textSize="13sp"
                        android:fontFamily="@font/googlesans_semibold"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/loginForm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/lblEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email Address"
                        android:visibility="gone"/>

                    <FrameLayout
                        android:id="@+id/usernameContainer"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_glass_input">
                        <ImageView
                            android:id="@+id/iconUsername"
                            android:layout_width="19dp"
                            android:layout_height="19dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="14dp"
                            android:src="@drawable/ic_lc_mail"
                            app:tint="#B8895A"
                            android:contentDescription="@null"/>
                        <EditText
                            android:id="@+id/etUsername"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:paddingStart="44dp"
                            android:paddingEnd="14dp"
                            android:hint="Email"
                            android:textColor="#1A1A18"
                            android:textColorHint="#A99E88"
                            android:inputType="textEmailAddress"
                            android:singleLine="true"
                            android:textSize="14sp"/>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/lblPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password"
                        android:visibility="gone"/>

                    <FrameLayout
                        android:id="@+id/passwordContainer"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="11dp"
                        android:background="@drawable/bg_glass_input">
                        <ImageView
                            android:id="@+id/iconPassword"
                            android:layout_width="19dp"
                            android:layout_height="19dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="14dp"
                            android:src="@drawable/ic_lc_lock"
                            app:tint="#B8895A"
                            android:contentDescription="@null"/>
                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:paddingStart="44dp"
                            android:paddingEnd="46dp"
                            android:hint="Enter your password"
                            android:textColor="#1A1A18"
                            android:textColorHint="#A99E88"
                            android:inputType="textPassword"
                            android:singleLine="true"
                            android:textSize="14sp"/>
                        <ImageView
                            android:id="@+id/btnTogglePassword"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginEnd="14dp"
                            android:src="@drawable/ic_lc_eye_off"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="#B8895A"
                            android:contentDescription="@null"/>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="9dp"
                        android:text="Forgot password?"
                        android:textColor="#0F6E56"
                        android:textSize="12sp"
                        android:fontFamily="@font/googlesans_medium"
                        android:background="?attr/selectableItemBackgroundBorderless"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_login_cta_green"
                        app:backgroundTint="@null"
                        android:text="Login"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textAllCaps="false"
                        android:fontFamily="@font/googlesans_semibold"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_cta_arrow"
                        app:iconGravity="textEnd"
                        app:iconTint="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/loginFooter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="14dp">
                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:src="@drawable/ic_security_login"
                        app:tint="#9A8F79"
                        android:contentDescription="@null"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="7dp"
                        android:text="Secured with enterprise-grade encryption"
                        android:textColor="#9A8F79"
                        android:textSize="10sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
