<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3F4F6">

    <!-- HEADER CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#2F2E2F">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvSupplierName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:text="Supplier"/>

            <View
                android:layout_width="32dp"
                android:layout_height="2dp"
                android:layout_marginVertical="6dp"
                android:background="#059669"/>

            <TextView
                android:id="@+id/tvInvoiceInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:text="Invoice #—  ·  —"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Scrollable body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- SUMMARY CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFBFF"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Taxable + GST row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TAXABLE"
                                android:textSize="10sp"
                                android:textColor="#9CA3AF"
                                android:letterSpacing="0.08"/>
                            <TextView
                                android:id="@+id/tvTaxableAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#111827"
                                android:text="₹0"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GST"
                                android:textSize="10sp"
                                android:textColor="#9CA3AF"
                                android:letterSpacing="0.08"/>
                            <TextView
                                android:id="@+id/tvGstAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#111827"
                                android:text="₹0"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TOTAL"
                                android:textSize="10sp"
                                android:textColor="#9CA3AF"
                                android:letterSpacing="0.08"/>
                            <TextView
                                android:id="@+id/tvTotalAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#059669"
                                android:text="₹0"/>
                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="10dp"
                        android:background="#F3F4F6"/>

                    <!-- Supplier GSTIN -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Supplier GSTIN"
                            android:textSize="12sp"
                            android:textColor="#6B7280"/>

                        <TextView
                            android:id="@+id/tvSupplierGstin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#374151"
                            android:text="—"/>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ITEMS SECTION HEADER -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="4dp"
                android:text="Line Items"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:textAllCaps="true"
                android:letterSpacing="0.08"/>

            <!-- ITEMS LIST (non-scrolling; nested inside ScrollView) -->
            <LinearLayout
                android:id="@+id/llPurchaseItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"/>

            <!-- PRIOR RETURNS HEADER -->
            <TextView
                android:id="@+id/tvPriorReturnsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="4dp"
                android:text="Prior Debit Notes"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:visibility="gone"/>

            <!-- PRIOR RETURNS LIST -->
            <LinearLayout
                android:id="@+id/llPriorReturns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM ACTION -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFBFF"
        app:strokeColor="#E5E7EB"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRaiseReturn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="50dp"
                android:text="Raise Return / Debit Note"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:backgroundTint="#059669"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_check_circle"
                app:iconPadding="8dp"
                app:iconGravity="textStart"
                app:iconTint="#FFFFFF"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClose"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:text="Close"
                android:textColor="#6B7280"
                android:textAllCaps="false"
                app:cornerRadius="12dp"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
