<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F0E6">

    <!-- ── HEADER (toolbar + title row, same as Import of Services) ── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        android:elevation="0dp"
        app:title=""
        app:titleTextColor="#1A1A18"
        app:navigationIconTint="#1A1A18" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Insights"
                android:textColor="#1A1A18"
                android:textSize="21sp"
                android:textStyle="bold"
                android:accessibilityHeading="true"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Business audit · powered by AI"
                android:textColor="#6E6A60"
                android:textSize="12sp"/>
        </LinearLayout>

        <ImageView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_imp_badge"
            android:backgroundTint="#FAEEDA"
            android:padding="8dp"
            android:src="@drawable/ic_sparkles"
            app:tint="#854F0B"
            android:contentDescription="@null"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp">

            <!-- ── AUDIT SCORE (ring + explanation) ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_imp_card"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <FrameLayout android:layout_width="58dp" android:layout_height="58dp">
                        <View android:id="@+id/viewAuditRing"
                            android:layout_width="58dp" android:layout_height="58dp"
                            android:background="@drawable/bg_audit_ring"
                            android:backgroundTint="#0F6E56"/>
                        <TextView android:id="@+id/tvPerformanceScore"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:text="--"
                            android:textColor="#0F6E56" android:textSize="17sp" android:textStyle="bold"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:orientation="vertical" android:layout_marginStart="14dp" android:layout_marginEnd="22dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Audit score" android:textColor="#6E6A60" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvScoreBadge"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="5dp" android:text="—"
                            android:textColor="#27500A" android:textSize="9sp" android:letterSpacing="0.06" android:textStyle="bold"
                            android:background="@drawable/bg_imp_badge" android:backgroundTint="#EAF3DE"
                            android:paddingHorizontal="7dp" android:paddingVertical="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="7dp" android:text="Your shop's health out of 100 — higher is better"
                            android:textColor="#9A968C" android:textSize="11sp" android:lineSpacingMultiplier="1.3"/>
                    </LinearLayout>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnScoreInfo"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="top|end"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_info_circle"
                    android:scaleType="centerInside"
                    android:padding="5dp"
                    app:tint="#9A968C"
                    android:contentDescription="What is the audit score?" />
            </FrameLayout>

            <!-- ── ROW 1: URGENT / LEAKS / WINS (color-block KPIs, inventory style) ── -->
            <LinearLayout
                android:id="@+id/bentoRow1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_imp_block_red"
                    android:padding="13dp">
                    <ImageView android:layout_width="17dp" android:layout_height="17dp"
                        android:src="@drawable/ic_kpi_alert" app:tint="#F7C1C1" android:contentDescription="@null"/>
                    <TextView android:id="@+id/tvKpiUrgent"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp" android:text="0"
                        android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="1dp" android:text="Urgent"
                        android:textColor="#F7C1C1" android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_imp_block_amber"
                    android:padding="13dp">
                    <ImageView android:layout_width="17dp" android:layout_height="17dp"
                        android:src="@drawable/ic_trending_down" app:tint="#FAC775" android:contentDescription="@null"/>
                    <TextView android:id="@+id/tvKpiLeaks"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp" android:text="0"
                        android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="1dp" android:text="Leaks"
                        android:textColor="#FAC775" android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_imp_block_green"
                    android:padding="13dp">
                    <ImageView android:layout_width="17dp" android:layout_height="17dp"
                        android:src="@drawable/ic_kpi_badge_check" app:tint="#9FE1CB" android:contentDescription="@null"/>
                    <TextView android:id="@+id/tvKpiWins"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp" android:text="0"
                        android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="1dp" android:text="Wins"
                        android:textColor="#9FE1CB" android:textSize="10sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── ROW 2: TOP PRODUCT VELOCITY (before insights) ── -->
            <LinearLayout
                android:id="@+id/bentoRow3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_imp_card"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Top product velocity"
                    android:textColor="#1A1A18"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TableLayout
                    android:id="@+id/tableProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*">
                    <TableRow android:paddingVertical="8dp">
                        <TextView
                            android:id="@+id/headerProduct"
                            android:layout_width="0dp"
                            android:layout_weight="2"
                            android:text="PRODUCT"
                            android:textColor="#9A968C"
                            android:textSize="10sp"
                            android:letterSpacing="0.04"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/headerQty"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="QTY"
                            android:gravity="center"
                            android:textColor="#9A968C"
                            android:textSize="10sp"
                            android:letterSpacing="0.04"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/headerRevenue"
                            android:layout_width="0dp"
                            android:layout_weight="1.2"
                            android:text="REVENUE"
                            android:gravity="end"
                            android:textColor="#9A968C"
                            android:textSize="10sp"
                            android:letterSpacing="0.04"
                            android:textStyle="bold"/>
                    </TableRow>
                </TableLayout>
            </LinearLayout>

            <!-- ── ROW 3: INSIGHTS LIST ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="2dp"
                android:paddingHorizontal="2dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Insights"
                    android:textColor="#1A1A18"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvInsightsSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#9A968C"
                    android:textSize="11sp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvInsights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:id="@+id/tvInsightsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No alerts right now — your shop looks healthy."
                android:textColor="#6E6A60"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="20dp"
                android:background="@drawable/bg_imp_card"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
