<?xml version="1.0" encoding="utf-8"?>
<!--
    Rounded translucent fill for the per-batch quantity EditText.

    Stroke colour is subtle by default and brightens on focus so the
    user gets immediate visual confirmation the field is editable.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#33FFFFFF" />
            <corners android:radius="10dp" />
            <stroke android:width="1.5dp" android:color="#FFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#22FFFFFF" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#55FFFFFF" />
        </shape>
    </item>
</selector>
