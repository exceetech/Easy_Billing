<?xml version="1.0" encoding="utf-8"?>
<!-- Premium graphite Print button with a fine gold inner hairline -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp"/>
            <solid android:color="#26241F"/>
        </shape>
    </item>

    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>
            <solid android:color="#00000000"/>
            <stroke android:width="1dp" android:color="#73D7B16E"/>
        </shape>
    </item>

</layer-list>
