<?xml version="1.0" encoding="utf-8"?>
<!--
    Minimalist inline minus button — flat, no fill, just a hairline
    border that flips to a soft red wash on press.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#FEE2E2"/>
            <stroke android:width="1dp" android:color="#FCA5A5"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent"/>
            <stroke android:width="1dp" android:color="#E5DDC9"/>
        </shape>
    </item>
</selector>
