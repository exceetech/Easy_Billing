<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#FBDADA"/>
            <stroke android:width="1dp" android:color="#E9B9B9"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#FFF5F5" android:endColor="#FCE9E9" android:angle="0"/>
            <stroke android:width="1dp" android:color="#F1CFCF"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</selector>
