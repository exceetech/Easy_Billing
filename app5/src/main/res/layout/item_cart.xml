<?xml version="1.0" encoding="utf-8"?>
<!--
    Cart row — editorial "lot entry" design.

    Inspired by luxury auction-house catalogues and Michelin
    tasting menus. Each row is a numbered LOT, separated from
    the next by a thin gold dotted rule rather than wrapped in
    a card. The result is a single continuous editorial sheet
    instead of the usual stack of independent cards.

    Layout (top → bottom):

      ┌──────────────────────────────────────────────────────┐
      │ ┃ ┃   M   Product Name                       ₹150   │
      │ │02│       ₹50 / kg                                  │
      │ ┃ ┃                                                  │
      │ ┃ ┃   ⊖  3  ⊕                                  ⌫    │
      │ ─ ─ ─ ─ ─  dotted gold divider  ─ ─ ─ ─ ─           │
      └──────────────────────────────────────────────────────┘

    Left column: a 2-digit serif lot number rendered in soft
    gold, paired with a vertical gold rail. Right of the rail:
    the monogram + product info on top, an unboxed inline
    stepper + minimal delete glyph on the bottom.

    All adapter IDs are preserved:
        tvLot · tvMonogram · viewMonogramBg · tvName · tvUnitPrice
        · tvPrice · btnMinus · tvQty · btnPlus · btnDelete
    (tvLot is new — populated from the adapter's `position`.)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="18dp"
    android:paddingBottom="0dp"
    android:paddingHorizontal="6dp"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- ───── Lot number column ───── -->
        <TextView
            android:id="@+id/tvLot"
            android:layout_width="34dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="01"
            android:textColor="#B6864A"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:includeFontPadding="false"/>

        <!-- ───── Vertical gold rail ───── -->
        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="14dp"
            android:background="@drawable/bg_lot_rail"/>

        <!-- ───── Item body (info + stepper) ───── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Top: monogram + name/unit + price -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="12dp">

                    <View
                        android:id="@+id/viewMonogramBg"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_monogram_ring"/>

                    <TextView
                        android:id="@+id/tvMonogram"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:includeFontPadding="false"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#0F0F12"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tvUnitPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#8A8377"
                        android:textSize="11sp"
                        android:letterSpacing="0.04"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#0F0F12"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"/>
            </LinearLayout>

            <!-- Bottom: minimalist inline stepper + delete glyph -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginTop="14dp"
                android:paddingStart="56dp"
                android:paddingEnd="0dp">

                <ImageButton
                    android:id="@+id/btnMinus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_minus"
                    android:scaleType="center"
                    android:background="@drawable/bg_inline_stepper_minus"
                    app:tint="#EF4444"/>

                <TextView
                    android:id="@+id/tvQty"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="#0F0F12"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"/>

                <ImageButton
                    android:id="@+id/btnPlus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_plus"
                    android:scaleType="center"
                    android:background="@drawable/bg_inline_stepper_plus"
                    app:tint="#16A34A"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <ImageButton
                    android:id="@+id/btnDelete"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/baseline_delete_24"
                    android:scaleType="center"
                    android:background="@drawable/bg_inline_delete"
                    app:tint="#9CA3AF"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Dotted gold divider — separates this lot from the next -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_dotted_gold_h"/>
</LinearLayout>
