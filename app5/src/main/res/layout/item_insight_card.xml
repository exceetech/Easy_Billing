<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardInsightBase"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvInsightIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_live_status_pill"
                android:gravity="center"
                android:text="🔥"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvInsightTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:fontFamily="serif"
                android:text="Imminent Stockout"
                android:textColor="#18181B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnMinimizeInsight"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="—"
                android:textColor="#A1A1AA"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvInsightDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="You have 3 items low on stock. Restock soon to prevent lost sales."
            android:textColor="#52525B"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInsightAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_gravity="end"
            android:text="Take Action"
            android:textAllCaps="false"
            app:cornerRadius="8dp"
            app:backgroundTint="#0F172A"
            android:visibility="gone"/>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
