<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_champagne"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <!-- Toolbar (same as inventory: transparent, back nav via BaseActivity) -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        android:elevation="0dp"
        app:title=""
        app:titleTextColor="#1A1A18"
        app:navigationIconTint="#1A1A18"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Sign-up-style frosted card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/monolithCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="36dp"
        android:layout_marginVertical="22dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#94FFFFFF"
        app:strokeColor="#CCFFFFFF"
        app:strokeWidth="1dp"
        app:layout_constraintWidth_max="660dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="26dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <!-- Lock badge -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/headerIconCard"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_success_circle">
                    <ImageView
                        android:layout_width="27dp"
                        android:layout_height="27dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_lc_lock"
                        app:tint="#0F6E56"
                        android:contentDescription="@null"/>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Eyebrow -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="ALMOST THERE"
                android:textColor="#B8895A"
                android:textSize="10sp"
                android:letterSpacing="0.16"
                android:fontFamily="@font/googlesans_semibold"/>

            <!-- Title -->
            <TextView
                android:id="@+id/headerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Set a new password"
                android:textColor="#1A1A18"
                android:textSize="22sp"
                android:fontFamily="serif"
                android:textStyle="bold"/>

            <!-- Subtitle -->
            <TextView
                android:id="@+id/headerSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:gravity="center"
                android:text="Create a strong password to keep your account safe."
                android:textColor="#6E6A60"
                android:textSize="12.5sp"
                android:lineSpacingExtra="2dp"/>

            <!-- Form -->
            <LinearLayout
                android:id="@+id/passwordSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp">

                <TextView
                    android:id="@+id/lblNewPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New password"
                    android:textColor="#6E6A60"
                    android:textSize="11.5sp"
                    android:fontFamily="@font/googlesans_semibold"
                    android:layout_marginBottom="6dp"/>

                <FrameLayout
                    android:id="@+id/passwordContainer"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_password_input">
                    <ImageView
                        android:id="@+id/iconPassword"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="13dp"
                        android:src="@drawable/ic_lc_lock"
                        app:tint="#B8895A"
                        android:contentDescription="@null"/>
                    <EditText
                        android:id="@+id/etNewPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:paddingStart="42dp"
                        android:paddingEnd="46dp"
                        android:hint="Enter new password"
                        android:textColor="#1A1A18"
                        android:textColorHint="#A99E88"
                        android:inputType="textPassword"
                        android:textCursorDrawable="@drawable/cursor_thin"
                        android:textSize="15sp"/>
                    <ImageView
                        android:id="@+id/btnToggleNewPass"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="13dp"
                        android:src="@drawable/ic_lc_eye_off"
                        app:tint="#A99E88"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Toggle password"/>
                </FrameLayout>

                <!-- Strength meter -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <View android:id="@+id/strengthSeg1"
                        android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                        android:layout_marginEnd="5dp" android:background="@drawable/bg_strength_seg"/>
                    <View android:id="@+id/strengthSeg2"
                        android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                        android:layout_marginEnd="5dp" android:background="@drawable/bg_strength_seg"/>
                    <View android:id="@+id/strengthSeg3"
                        android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                        android:layout_marginEnd="5dp" android:background="@drawable/bg_strength_seg"/>
                    <View android:id="@+id/strengthSeg4"
                        android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1"
                        android:background="@drawable/bg_strength_seg"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStrength"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text=""
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/lblConfirmPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm password"
                    android:textColor="#6E6A60"
                    android:textSize="11.5sp"
                    android:fontFamily="@font/googlesans_semibold"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="6dp"/>

                <FrameLayout
                    android:id="@+id/confirmPasswordContainer"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_password_input">
                    <ImageView
                        android:id="@+id/iconConfirmPassword"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="13dp"
                        android:src="@drawable/ic_lc_lock"
                        app:tint="#B8895A"
                        android:contentDescription="@null"/>
                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:paddingStart="42dp"
                        android:paddingEnd="46dp"
                        android:hint="Confirm your password"
                        android:textColor="#1A1A18"
                        android:textColorHint="#A99E88"
                        android:inputType="textPassword"
                        android:textCursorDrawable="@drawable/cursor_thin"
                        android:textSize="15sp"/>
                    <ImageView
                        android:id="@+id/btnToggleConfirmPass"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="13dp"
                        android:src="@drawable/ic_lc_eye_off"
                        app:tint="#A99E88"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Toggle password"/>
                </FrameLayout>

                <!-- Match row -->
                <LinearLayout
                    android:id="@+id/matchRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="7dp"
                    android:visibility="invisible">
                    <ImageView
                        android:id="@+id/ivMatch"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="6dp"
                        android:src="@drawable/ic_lc_check"
                        app:tint="#1D9E75"
                        android:contentDescription="@null"/>
                    <TextView
                        android:id="@+id/tvMatch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Passwords match"
                        android:textColor="#1D9E75"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!-- CTA -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_login_cta_green"
                    app:backgroundTint="@null"
                    android:text="Update password"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:fontFamily="@font/googlesans_semibold"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_cta_arrow"
                    app:iconGravity="textEnd"
                    app:iconTint="#FFFFFF"/>

                <!-- Footer -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remembered it? "
                        android:textColor="#6E6A60"
                        android:textSize="12.5sp"/>
                    <TextView
                        android:id="@+id/tvBackToLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Back to login"
                        android:textColor="#0F6E56"
                        android:textSize="12.5sp"
                        android:fontFamily="@font/googlesans_semibold"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
