<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_champagne">

    <!-- Toolbar (back affordance handled by BaseActivity) -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        android:elevation="0dp"
        app:title=""
        app:titleTextColor="#1A1A18"
        app:navigationIconTint="#1A1A18"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Sign-up-style frosted card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="36dp"
        android:layout_marginVertical="12dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#94FFFFFF"
        app:strokeColor="#CCFFFFFF"
        app:strokeWidth="1dp"
        app:layout_constraintWidth_max="660dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="18dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <!-- Mail badge -->
            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_success_circle">
                <ImageView
                    android:layout_width="27dp"
                    android:layout_height="27dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lc_mail"
                    app:tint="#0F6E56"
                    android:contentDescription="@null"/>
            </FrameLayout>

            <!-- Eyebrow -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="ACCOUNT VERIFICATION"
                android:textColor="#B8895A"
                android:textSize="10sp"
                android:letterSpacing="0.16"
                android:fontFamily="@font/googlesans_semibold"/>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Verify your email"
                android:textColor="#1A1A18"
                android:textSize="22sp"
                android:fontFamily="serif"
                android:textStyle="bold"/>

            <!-- Subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:gravity="center"
                android:text="Enter the 6-digit code we sent to"
                android:textColor="#6E6A60"
                android:textSize="12.5sp"
                android:lineSpacingExtra="2dp"/>

            <TextView
                android:id="@+id/tvOtpEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:text="your email"
                android:textColor="#1A1A18"
                android:textSize="12.5sp"
                android:fontFamily="@font/googlesans_semibold"/>

            <!-- OTP boxes -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/otpBox1"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:padding="0dp"
                    android:includeFontPadding="false"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textSize="18sp"
                    android:textColor="#1A1A18"
                    android:textCursorDrawable="@drawable/cursor_thin"
                    android:fontFamily="@font/googlesans_semibold"
                    android:importantForAutofill="no"
                    android:contentDescription="OTP digit 1"/>

                <EditText
                    android:id="@+id/otpBox2"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:padding="0dp"
                    android:includeFontPadding="false"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textSize="18sp"
                    android:textColor="#1A1A18"
                    android:textCursorDrawable="@drawable/cursor_thin"
                    android:fontFamily="@font/googlesans_semibold"
                    android:importantForAutofill="no"
                    android:contentDescription="OTP digit 2"/>

                <EditText
                    android:id="@+id/otpBox3"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:padding="0dp"
                    android:includeFontPadding="false"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textSize="18sp"
                    android:textColor="#1A1A18"
                    android:textCursorDrawable="@drawable/cursor_thin"
                    android:fontFamily="@font/googlesans_semibold"
                    android:importantForAutofill="no"
                    android:contentDescription="OTP digit 3"/>

                <EditText
                    android:id="@+id/otpBox4"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:padding="0dp"
                    android:includeFontPadding="false"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textSize="18sp"
                    android:textColor="#1A1A18"
                    android:textCursorDrawable="@drawable/cursor_thin"
                    android:fontFamily="@font/googlesans_semibold"
                    android:importantForAutofill="no"
                    android:contentDescription="OTP digit 4"/>

                <EditText
                    android:id="@+id/otpBox5"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:padding="0dp"
                    android:includeFontPadding="false"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textSize="18sp"
                    android:textColor="#1A1A18"
                    android:textCursorDrawable="@drawable/cursor_thin"
                    android:fontFamily="@font/googlesans_semibold"
                    android:importantForAutofill="no"
                    android:contentDescription="OTP digit 5"/>

                <EditText
                    android:id="@+id/otpBox6"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:padding="0dp"
                    android:includeFontPadding="false"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textSize="18sp"
                    android:textColor="#1A1A18"
                    android:textCursorDrawable="@drawable/cursor_thin"
                    android:fontFamily="@font/googlesans_semibold"
                    android:importantForAutofill="no"
                    android:contentDescription="OTP digit 6"/>

            </LinearLayout>

            <!-- Hidden aggregate field consumed by verify logic -->
            <EditText
                android:id="@+id/etOtp"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="invisible"
                android:inputType="number"
                android:maxLength="6"
                android:importantForAutofill="no"/>

            <!-- Validity hint -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:layout_marginEnd="6dp"
                    android:src="@drawable/ic_lc_clock"
                    app:tint="#0F6E56"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your code is valid for 5 minutes"
                    android:textColor="#A99E88"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Verify button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerify"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_login_cta_green"
                app:backgroundTint="@null"
                android:text="Verify code"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:fontFamily="@font/googlesans_semibold"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_cta_arrow"
                app:iconGravity="textEnd"
                app:iconTint="#FFFFFF"/>

            <!-- Resend row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Didn't receive it? "
                    android:textColor="#6E6A60"
                    android:textSize="12.5sp"/>
                <TextView
                    android:id="@+id/tvResendOtp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resend OTP"
                    android:textColor="#0F6E56"
                    android:textSize="12.5sp"
                    android:fontFamily="@font/googlesans_semibold"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
