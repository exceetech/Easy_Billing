<?xml version="1.0" encoding="utf-8"?>
<!-- Quantity pad enter: smooth slide from the right + fade.
     Only translate + alpha (GPU-composited) so it stays jank-free. -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:anim/decelerate_interpolator">
    <translate
        android:fromXDelta="30%p"
        android:toXDelta="0"
        android:duration="230"/>
    <alpha
        android:fromAlpha="0"
        android:toAlpha="1"
        android:duration="180"/>
</set>
