<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="7dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#99FFFFFF"
    app:strokeColor="#CCFFFFFF"
    app:strokeWidth="1dp"
    app:rippleColor="#140F6E56">

    <LinearLayout
        android:id="@+id/productContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- ── Row 1: monogram + stock pill ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">
                <View
                    android:id="@+id/viewProductMonogramBg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_product_monogram"/>
                <TextView
                    android:id="@+id/tvProductMonogram"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="#1A1A18"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"/>
            </FrameLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <LinearLayout
                android:id="@+id/pillStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_stock_pill"
                android:paddingStart="8dp"
                android:paddingEnd="9dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginTop="2dp">

                <View
                    android:id="@+id/viewStockDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/bg_stock_dot"/>

                <TextView
                    android:id="@+id/tvStockPill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#0F6E56"
                    android:fontFamily="@font/googlesans_semibold"
                    android:singleLine="true"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── Name + variant (inline) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginTop="11dp">

            <TextView
                android:id="@+id/tvProductName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#1A1A18"
                android:fontFamily="@font/googlesans_semibold"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingExtra="1dp"/>

            <TextView
                android:id="@+id/tvVariantName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:paddingBottom="1dp"
                android:textSize="11sp"
                android:textColor="#9A968C"
                android:singleLine="true"
                android:ellipsize="end"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- ── Meta: category chip ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tvListCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_category_chip"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textSize="10sp"
                android:textColor="#6B6B63"
                android:singleLine="true"
                android:visibility="gone"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvTranslatedName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textSize="11sp"
            android:textColor="#A1A1AA"
            android:singleLine="true"
            android:ellipsize="end"
            android:visibility="gone"/>

        <!-- ── Divider ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="11dp"
            android:background="#F0ECE0"/>

        <!-- ── Price + add ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:id="@+id/tvProductPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#0F6E56"
                    android:fontFamily="@font/googlesans_semibold"
                    android:includeFontPadding="false"
                    android:maxLines="1"/>

                <TextView
                    android:id="@+id/tvPriceUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:paddingBottom="1dp"
                    android:textSize="10sp"
                    android:textColor="#9A968C"
                    android:singleLine="true"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ivAddProduct"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_product_add"
                android:paddingStart="10dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_plus"
                    app:tint="#FFFFFF"
                    android:contentDescription="@null"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Add"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/googlesans_semibold"
                    android:includeFontPadding="false"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Out of stock overlay -->
    <FrameLayout
        android:id="@+id/flOutOfStockOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66FFFFFF"
        android:visibility="gone">
        <ImageView
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_gravity="center"
            android:alpha="0.7"
            android:src="@drawable/ic_out_of_stock"
            android:contentDescription="@null"/>
    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
