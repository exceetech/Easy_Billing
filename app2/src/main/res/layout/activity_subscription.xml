<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F5F7FA">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TITLE -->
        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            android:elevation="0dp"
            app:titleTextColor="@color/textPrimary"
            app:navigationIconTint="@color/textPrimary" />

        <!-- CARD -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- STATUS -->
            <TextView
                android:id="@+id/tvStatus"
                android:text="@string/checking"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- PLAN -->
            <TextView
                android:id="@+id/tvPlan"
                android:text="@string/plan"
                android:textSize="16sp"
                android:textColor="#374151"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- EXPIRY -->
            <TextView
                android:id="@+id/tvExpiry"
                android:text="@string/expiry"
                android:textSize="16sp"
                android:textColor="#374151"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- DAYS -->
            <TextView
                android:id="@+id/tvDaysLeft"
                android:text="@string/days_left"
                android:textSize="16sp"
                android:textColor="#374151"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- QR CARD -->
        <LinearLayout
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="@string/scan_and_pay"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#111827"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <ImageView
                android:id="@+id/imgQR"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:background="#FFFFFF"
                android:padding="10dp"/>

        </LinearLayout>

        <!-- BUTTONS -->
        <Button
            android:id="@+id/btnMonthly"
            android:text="@string/pay_monthly_999"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

        <Button
            android:id="@+id/btnYearly"
            android:text="@string/pay_yearly_9999"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_secondary"
            android:textColor="#111827"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

    </LinearLayout>

</ScrollView>