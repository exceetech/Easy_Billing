<?xml version="1.0" encoding="utf-8"?>
<!-- Outer concentric ring around the AI orb. Hairline-thin
     green stroke that pulses when the orb is animated. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@android:color/transparent"/>
    <stroke
        android:width="1dp"
        android:color="#3300FF88"/>
</shape>
