<?xml version="1.0" encoding="utf-8"?>
<!--
    AI Insight card surface.

    Soft white-cream base layered with a subtle diagonal mesh
    gradient (green ghost top-left, cream ghost bottom-right).
    The result is a deliberately "designed" card that sits
    cleanly against the dashboard backdrop without competing
    with the product tiles above.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp"/>
            <solid android:color="#FFFFFF"/>
            <stroke
                android:width="1dp"
                android:color="#1100FF88"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp"/>
            <gradient
                android:angle="135"
                android:startColor="#1500FF88"
                android:centerColor="#00FFFFFF"
                android:endColor="#0DD4A574"
                android:type="linear"/>
        </shape>
    </item>
</layer-list>
