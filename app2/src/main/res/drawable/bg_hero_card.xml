<?xml version="1.0" encoding="utf-8"?>
<!--
    Hero/header card — deep navy → indigo gradient. Pairs with a
    thin emerald accent line drawn in the layout for the "premium
    receipt" feel.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="28dp"/>
    <gradient
        android:startColor="#0B1220"
        android:centerColor="#101A33"
        android:endColor="#1B2A4A"
        android:angle="135"/>
    <stroke android:width="1dp" android:color="#1F2A44"/>
</shape>
