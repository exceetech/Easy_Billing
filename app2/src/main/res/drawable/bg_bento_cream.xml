<?xml version="1.0" encoding="utf-8"?>
<!--
    Cream bento panel — left half of the cart header.
    Soft white-cream gradient with a hairline gold border,
    rounded uniformly.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="22dp"/>
    <gradient
        android:startColor="#FFFFFF"
        android:endColor="#FBF6EB"
        android:angle="270"/>
    <stroke android:width="1dp" android:color="#EDE3CB"/>
</shape>
