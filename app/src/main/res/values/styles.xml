<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="QtyButton">
        <item name="android:textSize">18sp</item>
        <item name="android:layout_margin">4dp</item>
    </style>

    <style name="AppTextStyle">
        <item name="android:fontFamily">@font/googlesans</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextBold">
        <item name="android:fontFamily">@font/googlesans_bold</item>
    </style>

    <style name="TextMedium">
        <item name="android:fontFamily">@font/googlesans_medium</item>
    </style>

    <style name="PosKeypadButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">#EEF2FF</item>
        <item name="android:textColor">#1F2937</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PosKeypadButtonClear">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">#FEE2E2</item>
        <item name="android:textColor">#DC2626</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PosKeypadButtonDelete">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">#E0F2FE</item>
        <item name="android:textColor">#0369A1</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PaymentChip">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:padding">10dp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">#F1F3F6</item>
        <item name="android:textColor">#111</item>
    </style>

    <style name="CustomDialogTheme" parent="Theme.Material3.Light.Dialog.Alert">
        <item name="colorPrimary">#DC2626</item>
        <item name="android:textColorPrimary">#111827</item>
    </style>

    <style name="PosKeyTall">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">70dp</item>
        <item name="android:layout_columnWeight">1</item>

        <item name="android:textColor">#F8FAFC</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>

        <item name="backgroundTint">#1F2937</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="PosKeyClearTall">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_columnWeight">1</item>

        <item name="android:textColor">#EF4444</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>

        <item name="backgroundTint">#2D1F1F</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="PremiumButton" parent="Widget.Material3.Button">

        <!-- SIZE & SHAPE -->
        <item name="android:layout_height">58dp</item>
        <item name="cornerRadius">14dp</item>

        <!-- BACKGROUND -->
        <item name="backgroundTint">@null</item>
        <item name="android:background">@drawable/bg_premium_btn_ripple</item>

        <!-- DEPTH (less elevation, more control) -->
        <item name="android:elevation">2dp</item>
        <item name="android:stateListAnimator">@null</item>

        <!-- TEXT (this is where premium shows) -->
        <item name="android:textColor">#2A1D0C</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">true</item>

        <!-- PADDING (balanced, not bulky) -->
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>

        <!-- RIPPLE (liquid feel) -->
        <item name="rippleColor">#22EAD7A1</item>

        <!-- ICON SUPPORT -->
        <item name="iconGravity">textEnd</item>
        <item name="iconPadding">6dp</item>

    </style>

</resources>