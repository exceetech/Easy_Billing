    <style name="SiFieldBoxMulti">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">64dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">top</item>
        <item name="android:background">@drawable/bg_add_field</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">11dp</item>
    </style>

    <style name="SiIcon">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
        <item name="android:layout_marginEnd">9dp</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:contentDescription">@null</item>
    </style>

    <style name="SiEdit">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@null</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#1A1A18</item>
        <item name="android:textColorHint">#9CA3AF</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:paddingVertical">0dp</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="SiEditMulti">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@null</item>
        <item name="android:gravity">top</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#1A1A18</item>
        <item name="android:textColorHint">#9CA3AF</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:paddingVertical">0dp</item>
        <item name="android:inputType">textMultiLine|textCapSentences</item>
        <item name="android:minLines">2</item>
    </style>

    <style name="SiValue">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#1A1A18</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="SiSavePill">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginTop">22dp</item>
        <item name="backgroundTint">#1B3A8A</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="iconTint">#FFFFFF</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">8dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- ================= INVOICE DESIGN TOGGLES ================= -->
    <style name="IdToggleRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingVertical">13dp</item>
        <item name="android:clickable">true</item>
