<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ACTIVE STATE -->
    <item android:state_activated="true">
        <shape>
            <corners android:radius="14dp"/>
            <solid android:color="#121212"/>
            <stroke
                android:width="1.5dp"
                android:color="#00C853"/>
        </shape>
    </item>

    <!-- DEFAULT -->
    <item>
        <shape>
            <corners android:radius="14dp"/>
            <solid android:color="#121212"/>
            <stroke
                android:width="1dp"
                android:color="#2A2A2A"/>
        </shape>
    </item>

</selector>