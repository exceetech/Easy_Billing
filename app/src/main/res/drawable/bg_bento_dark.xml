<?xml version="1.0" encoding="utf-8"?>
<!--
    Dark bento panel — right half of the cart header.
    Deep obsidian gradient with a thin gold border.
    Hosts the premium count badge.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="22dp"/>
    <gradient
        android:startColor="#0F0F12"
        android:centerColor="#1B1B22"
        android:endColor="#2A2A33"
        android:angle="135"/>
    <stroke android:width="1dp" android:color="#D4A574"/>
</shape>
