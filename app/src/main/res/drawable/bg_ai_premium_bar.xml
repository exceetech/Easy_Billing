<?xml version="1.0" encoding="utf-8"?>
<!--
    Premium Obsidian Glass Ticker
    Deep black base with a subtle gradient and a phosphor-cyan top 'active' edge.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- The shadow/glow cast upwards into the product list -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00000000"
                android:endColor="#15000000"
                android:angle="90"/>
        </shape>
    </item>

    <!-- Main surface: Cream Butter with depth -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FAF8F5"
                android:endColor="#F3F0E9"
                android:angle="45"/>
        </shape>
    </item>

    <!-- Top Accent Hairline — Gold/Champagne Glow -->
    <item android:bottom="44dp">
        <shape android:shape="rectangle">
            <solid android:color="#D4A574"/>
        </shape>
    </item>

</layer-list>
