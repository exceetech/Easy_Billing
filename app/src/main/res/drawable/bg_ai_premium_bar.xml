<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Body: Premium Cream (Matches search bar) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp"/>
            <solid android:color="#EBE6DC"/>
            <stroke android:width="1dp" android:color="#DED6CA"/>
        </shape>
    </item>

    <!-- Subtle Depth Highlight -->
    <item android:bottom="36dp" android:left="12dp" android:right="12dp" android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp"/>
            <gradient
                android:angle="90"
                android:endColor="#1AFFFFFF"
                android:startColor="#00FFFFFF"/>
        </shape>
    </item>
</layer-list>
