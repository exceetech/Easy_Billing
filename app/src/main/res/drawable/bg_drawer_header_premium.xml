<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#FAF8F5"
                android:endColor="#F3EFE9"
                android:type="linear"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="380"
                android:centerX="0.95"
                android:centerY="0.20"
                android:startColor="#33D4A574"
                android:endColor="#00D4A574"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="320"
                android:centerX="0.10"
                android:centerY="0.85"
                android:startColor="#1100FF88"
                android:endColor="#0000FF88"/>
        </shape>
    </item>
</layer-list>
