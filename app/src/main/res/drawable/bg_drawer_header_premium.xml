<?xml version="1.0" encoding="utf-8"?>
<!-- Drawer header — same midnight + champagne language as the
     login backdrop, scoped to the smaller surface. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#0A0E1A"
                android:endColor="#13182A"
                android:type="linear"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="380"
                android:centerX="0.95"
                android:centerY="0.20"
                android:startColor="#33D4A574"
                android:endColor="#00D4A574"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="320"
                android:centerX="0.10"
                android:centerY="0.85"
                android:startColor="#222B3A6F"
                android:endColor="#002B3A6F"/>
        </shape>
    </item>
</layer-list>
