<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow / Shadow -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="40dp"
                android:startColor="#15000000"
                android:endColor="#00000000"/>
        </shape>
    </item>

    <!-- Base Surface: Deep Graphite Gradient -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#2D2D35"
                android:endColor="#0F0F12"/>
            <stroke
                android:width="1.5dp"
                android:color="#D4A574"/> <!-- Editorial Gold Border -->
        </shape>
    </item>

    <!-- Inner Highlight for Depth -->
    <item android:top="4dp" android:bottom="4dp" android:left="4dp" android:right="4dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#10FFFFFF"
                android:endColor="#00FFFFFF"/>
        </shape>
    </item>
</layer-list>
