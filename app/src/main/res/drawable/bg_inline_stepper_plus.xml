<?xml version="1.0" encoding="utf-8"?>
<!--
    Minimalist inline plus button — pairs with bg_inline_stepper_minus.
    Active state flips to gold to match the editorial palette.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#D4A574"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent"/>
            <stroke android:width="1dp" android:color="#E5DDC9"/>
        </shape>
    </item>
</selector>
