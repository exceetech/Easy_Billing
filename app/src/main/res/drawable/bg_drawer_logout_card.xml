<?xml version="1.0" encoding="utf-8"?>
<!--
    Logout pill — soft red wash with red stroke. Sits at the
    bottom of the drawer and visually separates the destructive
    action from the navigation rows.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape>
            <corners android:radius="14dp"/>
            <solid android:color="#33EF4444"/>
            <stroke
                android:width="1dp"
                android:color="#55EF4444"/>
        </shape>
    </item>

    <item>
        <shape>
            <corners android:radius="14dp"/>
            <solid android:color="#0DEF4444"/>
            <stroke
                android:width="1dp"
                android:color="#22EF4444"/>
        </shape>
    </item>
</selector>
