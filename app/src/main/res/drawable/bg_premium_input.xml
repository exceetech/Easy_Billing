<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- FOCUSED / ACTIVATED STATE -->
    <item android:state_activated="true">
        <layer-list>
            <!-- Outer Glow / Accent Shadow -->
            <item>
                <shape>
                    <solid android:color="#0D6366F1" /> <!-- 5% Indigo Glow -->
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <!-- Main Box -->
            <item android:bottom="2dp" android:left="2dp" android:right="2dp" android:top="2dp">
                <shape>
                    <solid android:color="#FFFFFF" />
                    <stroke android:width="2dp" android:color="#6366F1" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- DEFAULT STATE -->
    <item>
        <shape>
            <solid android:color="#F8FAFC" /> <!-- Subtle 'recessed' look -->
            <stroke android:width="1.5dp" android:color="#E2E8F0" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
