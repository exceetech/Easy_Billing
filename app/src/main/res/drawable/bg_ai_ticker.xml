<?xml version="1.0" encoding="utf-8"?>
<!--
    Slim AI ticker bar — pure black surface with a thin
    phosphor-green top hairline. No card chrome, no margin —
    just a blade of running text under the products grid.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#000000"/>
        </shape>
    </item>

    <!-- 1px green top edge — the only "designed" detail. -->
    <item android:bottom="-2dp" android:left="-2dp" android:right="-2dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
            <stroke
                android:width="1dp"
                android:color="#3300FF88"/>
        </shape>
    </item>
</layer-list>
