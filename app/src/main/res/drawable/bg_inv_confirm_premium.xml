<?xml version="1.0" encoding="utf-8"?>
<!-- Premium confirm CTA: deep emerald gradient with a fine gold inner hairline -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Emerald body -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp"/>
            <gradient
                android:startColor="#16A34A"
                android:centerColor="#15803D"
                android:endColor="#0F6E33"
                android:angle="270"/>
        </shape>
    </item>

    <!-- Gold inner hairline, inset from the edge -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>
            <solid android:color="#00000000"/>
            <stroke android:width="1dp" android:color="#63D7B16E"/>
        </shape>
    </item>

</layer-list>
