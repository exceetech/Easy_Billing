<?xml version="1.0" encoding="utf-8"?>
<!--
    Horizontal dotted gold divider — 1dp dashed stroke. Used at
    the bottom of every cart "lot" row so the items read as
    entries in a luxury folio rather than detached cards.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="line">
    <stroke
        android:width="1dp"
        android:color="#D4A574"
        android:dashWidth="2dp"
        android:dashGap="3dp"/>
    <size android:height="1dp"/>
</shape>
