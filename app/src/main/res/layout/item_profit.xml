<com.google.android.material.card.MaterialCardView android:layout_margin="8dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:padding="12dp"
        android:orientation="vertical"
        android:layout_height="wrap_content"
        android:layout_width="match_parent">

        <TextView
            android:id="@+id/tvName"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <TextView android:id="@+id/tvQty"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"/>
        <TextView android:id="@+id/tvRevenue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvProfit"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"/>

        <!-- 🔥 STOCK FLOW -->
        <TextView
            android:id="@+id/tvStockFlow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Added: 0 | Sold: 0 | Loss: 0"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:layout_marginTop="4dp"/>

        <!-- 🔥 REMAINING -->
        <TextView
            android:id="@+id/tvRemaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remaining: 0"
            android:textSize="12sp"
            android:textColor="#374151"/>

        <!-- 🔥 LOSS -->
        <TextView
            android:id="@+id/tvLoss"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loss: ₹0"
            android:textSize="12sp"
            android:textColor="#EF4444"/>

        <!-- 🔥 NET PROFIT -->
        <TextView
            android:id="@+id/tvNetProfit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Net Profit: ₹0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#16A34A"/>

        <!-- 🔥 ANALYSIS -->
        <TextView
            android:id="@+id/tvInsight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Insight"
            android:textSize="12sp"
            android:textColor="#2563EB"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>