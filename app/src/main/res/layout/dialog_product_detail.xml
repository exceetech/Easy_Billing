<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_popup_cream"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="18dp"
        android:paddingBottom="18dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:gravity="center"
                android:background="@drawable/bg_imp_badge"
                android:backgroundTint="#EAF3DE"
                android:text="AA"
                android:textColor="#0F6E56"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Product name"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A18"
                    android:maxLines="2"
                    android:ellipsize="end"/>
                <TextView
                    android:id="@+id/tvNameSub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="—"
                    android:textSize="11.5sp"
                    android:textColor="#9A968C"
                    android:singleLine="true"
                    android:ellipsize="end"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/chipInsight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_low"
                android:paddingHorizontal="9dp"
                android:paddingVertical="4dp">
                <ImageView
                    android:id="@+id/ivInsight"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="4dp"
                    android:src="@drawable/ic_check_circle"
                    app:tint="#3B6D11"
                    android:contentDescription="@null"/>
                <TextView
                    android:id="@+id/tvInsight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good product"
                    android:textSize="10.5sp"
                    android:textStyle="bold"
                    android:textColor="#3B6D11"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Net profit hero -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:background="@drawable/bg_imp_card"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            android:padding="15dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NET PROFIT"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:textColor="#9A968C"/>
                <TextView
                    android:id="@+id/tvNetProfit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="₹0.00"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#0F6E56"
                    android:singleLine="true"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMarginPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_inv_a_trend_pill"
                android:backgroundTint="#11402F"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp">
                <ImageView
                    android:id="@+id/ivMargin"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="3dp"
                    android:src="@drawable/ic_si_trend_up"
                    app:tint="#7DDCB2"
                    android:contentDescription="@null"/>
                <TextView
                    android:id="@+id/tvMargin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0% margin"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#7DDCB2"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Financial grid 2x2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp">
            <LinearLayout style="@style/PdStatCard" android:layout_marginEnd="10dp">
                <TextView style="@style/PdStatLabel" android:text="Revenue"/>
                <TextView android:id="@+id/tvRevenue" style="@style/PdStatValue" android:text="₹0.00"/>
            </LinearLayout>
            <LinearLayout style="@style/PdStatCard">
                <TextView style="@style/PdStatLabel" android:text="Cost"/>
                <TextView android:id="@+id/tvCost" style="@style/PdStatValue" android:text="₹0.00"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp">
            <LinearLayout style="@style/PdStatCard" android:layout_marginEnd="10dp">
                <TextView style="@style/PdStatLabel" android:text="Gross profit"/>
                <TextView android:id="@+id/tvProfit" style="@style/PdStatValue"
                    android:textColor="#0F6E56" android:text="₹0.00"/>
            </LinearLayout>
            <LinearLayout style="@style/PdStatCard">
                <TextView style="@style/PdStatLabel" android:text="Loss"/>
                <TextView android:id="@+id/tvLoss" style="@style/PdStatValue"
                    android:textColor="#A32D2D" android:text="₹0.00"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Stock flow -->
        <TextView style="@style/AddSectionLabel" android:text="STOCK FLOW"
            android:layout_marginStart="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_imp_card"
            android:layout_marginHorizontal="16dp"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="7dp">
                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:textSize="11sp" android:textColor="#9A968C" android:text="Stock movement"/>
                <TextView
                    android:id="@+id/tvAdded"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#1A1A18" android:textStyle="bold"
                    android:text="Added 0"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_bar_track"
                android:clipToOutline="true">
                <View android:id="@+id/barSold" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:background="#1D9E75"/>
                <View android:id="@+id/barLoss" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="0" android:background="#E24B4A"/>
                <View android:id="@+id/barRemaining" android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="0" android:background="#D3D1C7"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="9dp">
                <TextView android:id="@+id/tvSold" style="@style/PdLegend"
                    android:textColor="#0F6E56" android:text="● Sold 0"/>
                <TextView android:id="@+id/tvLossQty" style="@style/PdLegend"
                    android:layout_marginStart="14dp"
                    android:textColor="#A32D2D" android:text="● Loss 0"/>
                <TextView android:id="@+id/tvRemaining" style="@style/PdLegend"
                    android:layout_marginStart="14dp"
                    android:textColor="#6E6A60" android:text="● Remaining 0"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Close -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="18dp"
            android:text="Close"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            app:backgroundTint="#1B3A8A"
            app:cornerRadius="14dp"
            android:stateListAnimator="@null"
            android:elevation="0dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
