<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_rounded"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- ICON -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:layout_marginBottom="12dp"
        android:src="@android:drawable/ic_delete"
        app:tint="#EF4444" />

    <!-- TITLE -->
    <TextView
        android:text="Clear Stock"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- MESSAGE -->
    <TextView
        android:text="Are you sure you want to remove all stock?"
        android:textSize="14sp"
        android:textColor="#6B7280"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <RadioGroup
        android:id="@+id/rgType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <RadioButton
            android:id="@+id/rbDamage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Damaged / Expired"/>

        <RadioButton
            android:id="@+id/rbAdjust"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stock Correction"/>
    </RadioGroup>

    <!-- BUTTON ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <!-- CANCEL -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="Cancel"
            android:textColor="#111827"
            app:cornerRadius="12dp"
            app:backgroundTint="#E5E7EB"
            app:rippleColor="?attr/colorControlHighlight"/>

        <View
            android:layout_width="10dp"
            android:layout_height="1dp"/>

        <!-- CLEAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="Clear"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:cornerRadius="12dp"
            app:backgroundTint="#EF4444"
            app:rippleColor="#33FFFFFF"/>
    </LinearLayout>

</LinearLayout>