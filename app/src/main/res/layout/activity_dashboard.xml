<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ================= MAIN CONTENT ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"
        android:orientation="vertical"
        android:background="@drawable/img_2"
        android:focusableInTouchMode="true"
        android:clickable="true">

        <!-- ================= TOP BAR ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="#FAFAFA"
            android:elevation="4dp">

            <!-- Menu -->
            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu"
                android:contentDescription="@string/menu"/>

            <!-- Welcome -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:text="@string/welcome"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- Cart with Badge -->
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

                <ImageView
                    android:id="@+id/btnCart"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_cart"
                    android:contentDescription="@string/cart"/>

                <TextView
                    android:id="@+id/tvCartBadge"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="end|top"
                    android:background="@drawable/badge_background"
                    android:text="@string/_0"
                    android:textSize="9sp"
                    android:textColor="@android:color/white"
                    android:gravity="center"
                    android:visibility="gone"/>
            </FrameLayout>

        </LinearLayout>

        <!-- ================= SEARCH BAR ================= -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"


            app:cardCornerRadius="24dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="#FAFAFA"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:orientation="vertical">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    app:startIconDrawable="@drawable/ic_search"
                    app:startIconTint="?attr/colorPrimary"
                    app:endIconMode="clear_text"

                    app:boxBackgroundMode="none"

                    app:boxCornerRadiusTopStart="20dp"
                    app:boxCornerRadiusTopEnd="20dp"
                    app:boxCornerRadiusBottomStart="20dp"
                    app:boxCornerRadiusBottomEnd="20dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"

                        android:gravity="center_vertical"
                        android:includeFontPadding="false"

                        android:hint="@string/search_products"

                        android:inputType="text"
                        android:maxLength="50"
                        android:singleLine="true"
                        android:imeOptions="actionSearch"

                        android:importantForAutofill="no"
                        android:autofillHints=""

                        android:paddingStart="4dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"

                        android:textColor="#000000"
                        android:textColorHint="#888888" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ================= PRODUCTS ================= -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProducts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp"
            android:clipToPadding="false"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNoticeBoard"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_margin="16dp"

            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- icon -->

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="@string/todo"
                    android:src="@drawable/ic_ai"
                    app:tint="#F59E0B"/>

                <!-- running notice -->

                <TextView
                    android:id="@+id/tvNoticeBoard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"

                    android:text="@string/loading_ai_suggestions"
                    android:textSize="15sp"
                    android:textColor="#92400E"

                    android:singleLine="true"
                    android:ellipsize="marquee"

                    android:marqueeRepeatLimit="marquee_forever"
                    android:focusable="true"
                    android:focusableInTouchMode="true"

                    android:layout_marginStart="12dp"/>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- ================= LEFT MENU DRAWER ================= -->
    <LinearLayout
        android:id="@+id/leftDrawer"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="?attr/colorSurface"
        android:paddingTop="40dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_menu"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"/>

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_marginTop="8dp"
                android:background="?attr/colorPrimary"/>
        </LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E7EB"
            android:layout_marginBottom="16dp"/>

        <!-- MENU ITEMS -->

        <!-- TRANSLATION TOGGLE -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"

            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#EEF2FF"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_language"
                    app:tint="?attr/colorPrimary"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_translation"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginStart="14dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchTranslate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdmin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/add_products"
            android:textAllCaps="false"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"

            app:icon="@drawable/ic_addproduct"
            app:iconGravity="textStart"
            app:iconPadding="16dp"
            app:iconSize="28dp"
            app:iconTint="?attr/colorPrimary"

            style="@style/Widget.Material3.Button.TextButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPreviousBills"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/bill_history"
            android:textAllCaps="false"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"

            app:icon="@drawable/ic_history"
            app:iconGravity="textStart"
            app:iconPadding="16dp"
            app:iconSize="28dp"
            app:iconTint="?attr/colorPrimary"

            style="@style/Widget.Material3.Button.TextButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/settings"
            android:textAllCaps="false"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"

            app:icon="@drawable/ic_settings"
            app:iconGravity="textStart"
            app:iconPadding="16dp"
            app:iconSize="28dp"
            app:iconTint="?attr/colorPrimary"

            style="@style/Widget.Material3.Button.TextButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReports"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/reports"
            android:textAllCaps="false"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"

            app:icon="@drawable/ic_report"
            app:iconGravity="textStart"
            app:iconPadding="16dp"
            app:iconSize="28dp"
            app:iconTint="?attr/colorPrimary"

            style="@style/Widget.Material3.Button.TextButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAiInsights"
            android:layout_width="match_parent"
            android:layout_height="56dp"

            android:text="@string/ai_insights"
            android:textAllCaps="false"

            android:gravity="start|center_vertical"
            android:paddingStart="16dp"

            app:icon="@drawable/ic_ai"
            app:iconGravity="textStart"
            app:iconPadding="16dp"
            app:iconSize="28dp"
            app:iconTint="?attr/colorPrimary"

            style="@style/Widget.Material3.Button.TextButton"/>

        <!-- SPACE -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- LOGOUT SECTION -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E7EB"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/logout"
            android:textAllCaps="false"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:textColor="?attr/colorError"

            app:icon="@drawable/ic_logout"
            app:iconGravity="textStart"
            app:iconPadding="16dp"
            app:iconSize="28dp"
            app:iconTint="?attr/colorError"

            style="@style/Widget.Material3.Button.TextButton"/>

    </LinearLayout>

    <!-- ================= RIGHT CART DRAWER ================= -->
    <LinearLayout
        android:id="@+id/cartDrawer"
        android:layout_width="480dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="12dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/cart"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"/>

        <!-- Cart Items -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCart"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:clipToPadding="false"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"/>

        <!-- Bottom Summary -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#FAFAFA">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/total"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tvTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/_0"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateBill"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="@string/generate_bill"
                app:cornerRadius="12dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>