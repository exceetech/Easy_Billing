<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <!-- MAIN CONTAINER CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mainContainerCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="32dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeWidth="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Split Guideline (Form Left 45%, Branding Right 55%) -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/cardGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.45" />

            <!-- LEFT PANE: REGISTER FORM -->
            <ScrollView
                android:id="@+id/registerContainer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="#FFFFFF"
                android:fillViewport="true"
                android:scrollbars="none"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/cardGuideline">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="60dp"
                    android:paddingVertical="48dp">

                    <!-- Register Header -->
                    <LinearLayout
                        android:id="@+id/registerHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/registerForm"
                        app:layout_constraintVertical_bias="0">

                        <TextView
                            android:id="@+id/tvRegisterTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Create Account ✨"
                            android:textSize="34sp"
                            android:textColor="#0F172A"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Set up your shop in minutes and start billing today."
                            android:textSize="16sp"
                            android:textColor="#64748B"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>

                    <!-- Form Fields -->
                    <LinearLayout
                        android:id="@+id/registerForm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="20dp"
                        app:layout_constraintTop_toBottomOf="@id/registerHeader"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <!-- Full Name -->
                        <TextView
                            android:id="@+id/lblFullName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Full Name"
                            android:textSize="14sp"
                            android:textColor="#334155"
                            android:layout_marginBottom="8dp"
                            android:textStyle="bold"/>

                        <FrameLayout
                            android:id="@+id/nameContainer"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_premium_input">
                            <ImageView
                                android:id="@+id/iconFullName"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center_vertical|start"
                                android:layout_marginStart="16dp"
                                android:src="@drawable/ic_person"
                                app:tint="#94A3B8"/>
                            <EditText
                                android:id="@+id/etFullName"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:paddingStart="48dp"
                                android:paddingEnd="16dp"
                                android:hint="Enter your full name"
                                android:textColor="#0F172A"
                                android:textColorHint="#94A3B8"
                                android:inputType="textCapWords"
                                android:imeOptions="actionNext"
                                android:singleLine="true"
                                android:textSize="15sp" />
                        </FrameLayout>

                        <!-- Email -->
                        <TextView
                            android:id="@+id/lblEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email Address"
                            android:textSize="14sp"
                            android:textColor="#334155"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="8dp"
                            android:textStyle="bold"/>

                        <FrameLayout
                            android:id="@+id/emailContainer"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_premium_input">
                            <ImageView
                                android:id="@+id/iconEmail"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center_vertical|start"
                                android:layout_marginStart="16dp"
                                android:src="@drawable/ic_mail"
                                app:tint="#94A3B8"/>
                            <EditText
                                android:id="@+id/etEmail"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:paddingStart="48dp"
                                android:paddingEnd="16dp"
                                android:hint="Enter your email"
                                android:textColor="#0F172A"
                                android:textColorHint="#94A3B8"
                                android:inputType="textEmailAddress"
                                android:imeOptions="actionNext"
                                android:singleLine="true"
                                android:textSize="15sp" />
                        </FrameLayout>

                        <!-- Phone -->
                        <TextView
                            android:id="@+id/lblPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phone Number"
                            android:textSize="14sp"
                            android:textColor="#334155"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="8dp"
                            android:textStyle="bold"/>

                        <FrameLayout
                            android:id="@+id/phoneContainer"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_premium_input">
                            <ImageView
                                android:id="@+id/iconPhone"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center_vertical|start"
                                android:layout_marginStart="16dp"
                                android:src="@drawable/ic_phone"
                                app:tint="#94A3B8"/>
                            <EditText
                                android:id="@+id/etPhoneNumber"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:paddingStart="48dp"
                                android:paddingEnd="16dp"
                                android:hint="Enter your phone"
                                android:textColor="#0F172A"
                                android:textColorHint="#94A3B8"
                                android:inputType="phone"
                                android:imeOptions="actionNext"
                                android:singleLine="true"
                                android:textSize="15sp" />
                        </FrameLayout>

                        <!-- Shop Name -->
                        <TextView
                            android:id="@+id/lblShopName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Shop Name"
                            android:textSize="14sp"
                            android:textColor="#334155"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="8dp"
                            android:textStyle="bold"/>

                        <FrameLayout
                            android:id="@+id/shopContainer"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_premium_input">
                            <ImageView
                                android:id="@+id/iconShop"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center_vertical|start"
                                android:layout_marginStart="16dp"
                                android:src="@drawable/ic_store"
                                app:tint="#94A3B8"/>
                            <EditText
                                android:id="@+id/ShopName"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:paddingStart="48dp"
                                android:paddingEnd="16dp"
                                android:hint="Enter your shop name"
                                android:textColor="#0F172A"
                                android:textColorHint="#94A3B8"
                                android:inputType="textCapWords"
                                android:imeOptions="actionDone"
                                android:singleLine="true"
                                android:textSize="15sp" />
                        </FrameLayout>

                        <!-- Register Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRegister"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="28dp"
                            android:background="@drawable/bg_indigo_purple_gradient"
                            app:backgroundTint="@null"
                            android:text="Create Account"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textAllCaps="false"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/ic_arrow_forward"
                            app:iconGravity="textEnd"
                            app:iconTint="#FFFFFF" />

                        <!-- Divider -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="28dp">
                            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#000000"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="or"
                                android:textColor="#000000"
                                android:textSize="14sp"
                                android:layout_marginHorizontal="16dp" />
                            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#000000"/>
                        </LinearLayout>

                        <!-- Back to Login -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="20dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Already have an account? "
                                android:textColor="#64748B"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvBackToLogin"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Log In"
                                android:textColor="#4F46E5"
                                android:textSize="14sp"
                                android:background="?attr/selectableItemBackgroundBorderless"/>
                        </LinearLayout>
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </ScrollView>

            <!-- RIGHT PANE: BRANDING (Material Card for rounded corners) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/brandingPane"
                android:transitionName="shared_branding_pane"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                app:cardCornerRadius="20dp"
                app:cardElevation="25dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:layout_constraintStart_toEndOf="@id/cardGuideline"
                app:layout_constraintEnd_toEndOf="parent">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                <!-- Background Image -->
                <ImageView
                    android:id="@+id/imgIllustration"
                    android:transitionName="shared_image_pane"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/img_login1"
                    android:scaleType="centerCrop" />

                <!-- Top Scrim for Readability: Blends the image top with the layout -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:background="@drawable/bg_top_scrim"/>

                <!-- Content Overlay -->
                <LinearLayout
                    android:id="@+id/brandingContent"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingTop="36dp"
                    android:paddingHorizontal="6dp"
                    android:paddingBottom="12dp">

                    <!-- Branding Section -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="32dp">

                        <ImageView
                            android:id="@+id/brandLogo"
                            android:layout_width="52dp"
                            android:layout_height="52dp"/>

                        <LinearLayout
                            android:id="@+id/brandTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ex"
                                    android:textSize="42sp"
                                    android:textColor="#0F172A"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="POS"
                                    android:textSize="42sp"
                                    android:textColor="#6366F1"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Retail  •  Restaurant  •  Bakery  •  Grocery"
                                android:textSize="14sp"
                                android:textColor="#3E607C"
                                android:letterSpacing="0.02"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/brandTagline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Join thousands of businesses\nthat trust ExPOS every day."
                        android:textSize="16sp"
                        android:textColor="#3E607C"
                        android:layout_marginHorizontal="30dp"
                        android:lineSpacingExtra="4dp" />

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                    <!-- Bottom Features Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/brandFeatures"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="24dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="@android:color/transparent">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingVertical="14dp"
                                android:paddingHorizontal="12dp"
                                android:gravity="center"
                                android:baselineAligned="false">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:gravity="center">
                                    <FrameLayout
                                        android:layout_width="60dp"
                                        android:layout_height="60dp"
                                        android:background="@drawable/bg_circle_primary">

                                        <ImageView
                                            android:layout_width="40dp"
                                            android:layout_height="40dp"
                                            android:layout_gravity="center"
                                            android:src="@drawable/ic_bill_login"
                                            app:tint="#FFFFFF" />
                                    </FrameLayout>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="6dp"
                                        android:text="Easy\nBilling"
                                        android:textSize="14sp"
                                        android:textColor="#3E607C"
                                        android:gravity="center" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:gravity="center">
                                    <FrameLayout
                                        android:layout_width="60dp"
                                        android:layout_height="60dp"
                                        android:background="@drawable/bg_circle_orange">

                                        <ImageView
                                            android:layout_width="40dp"
                                            android:layout_height="40dp"
                                            android:layout_gravity="center"
                                            android:src="@drawable/ic_inventory_login"
                                            app:tint="#FFFFFF" />
                                    </FrameLayout>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="6dp"
                                        android:text="Inventory\nManagement"
                                        android:textSize="14sp"
                                        android:textColor="#3E607C"
                                        android:gravity="center" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:gravity="center">
                                    <FrameLayout
                                        android:layout_width="60dp"
                                        android:layout_height="60dp"
                                        android:background="@drawable/bg_circle_green">

                                        <ImageView
                                            android:layout_width="40dp"
                                            android:layout_height="40dp"
                                            android:layout_gravity="center"
                                            android:src="@drawable/ic_graph_login"
                                            app:tint="#FFFFFF" />
                                    </FrameLayout>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="6dp"
                                        android:text="Sales\nAnalytics"
                                        android:textSize="14sp"
                                        android:textColor="#3E607C"
                                        android:gravity="center" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:gravity="center">
                                    <FrameLayout
                                        android:layout_width="60dp"
                                        android:layout_height="60dp"
                                        android:background="@drawable/bg_circle_pink">

                                        <ImageView
                                            android:layout_width="40dp"
                                            android:layout_height="40dp"
                                            android:layout_gravity="center"
                                            android:src="@drawable/ic_shop_login"
                                            app:tint="#FFFFFF" />
                                    </FrameLayout>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="6dp"
                                        android:text="Multi-Store\nSupport"
                                        android:textSize="14sp"
                                        android:textColor="#3E607C"
                                        android:gravity="center" />
                                </LinearLayout>
                            </LinearLayout>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
