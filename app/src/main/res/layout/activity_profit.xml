

<LinearLayout

    xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:orientation="vertical"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    android:background="#F9FAFB">

    <!-- ================= TOOLBAR ================= -->

    <com.google.android.material.appbar.MaterialToolbar

        android:id="@+id/toolbar"

        android:layout_width="match_parent"

        android:layout_height="?attr/actionBarSize"

        android:background="@android:color/transparent"

        android:elevation="0dp"

        app:titleTextColor="@color/textPrimary"

        app:navigationIconTint="@color/textPrimary" />

    <!-- ================= FILTERS ================= -->

    <HorizontalScrollView

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:padding="12dp"

        android:scrollbars="none">

        <LinearLayout

            android:id="@+id/filterContainer"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:orientation="horizontal">

            <!-- KEEP YOUR ORIGINAL BUTTONS -->

            <com.google.android.material.button.MaterialButton

                android:id="@+id/btnToday"

                android:layout_width="wrap_content"

                android:layout_height="40dp"

                android:text="Today"/>

            <com.google.android.material.button.MaterialButton

                android:id="@+id/btnWeek"

                android:layout_width="wrap_content"

                android:layout_height="40dp"

                android:text="Week"/>

            <com.google.android.material.button.MaterialButton

                android:id="@+id/btnMonth"

                android:layout_width="wrap_content"

                android:layout_height="40dp"

                android:text="Month"/>

            <com.google.android.material.button.MaterialButton

                android:id="@+id/btnAll"

                android:layout_width="wrap_content"

                android:layout_height="40dp"

                android:text="All"/>

            <com.google.android.material.button.MaterialButton

                android:id="@+id/btnCustom"

                android:layout_width="wrap_content"

                android:layout_height="40dp"

                android:text="Custom"/>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- ================= SEARCH + CHART ================= -->

    <LinearLayout

        android:layout_width="match_parent"

        android:layout_height="50dp"

        android:paddingHorizontal="12dp"

        android:gravity="center_vertical"

        android:orientation="horizontal">

        <EditText

            android:id="@+id/etSearch"

            android:layout_width="0dp"

            android:layout_height="40dp"

            android:layout_weight="1"

            android:hint="Search products..."

            android:background="@drawable/bg_search"

            android:paddingHorizontal="12dp"

            android:textSize="14sp"/>

        <ImageButton

            android:id="@+id/btnChart"

            android:layout_width="40dp"

            android:layout_height="40dp"

            android:layout_marginStart="10dp"

            android:background="@drawable/bg_circle"

            android:src="@drawable/ic_chart"

            android:padding="8dp"/>

    </LinearLayout>

    <!-- ================= PREMIUM PROFIT KPI ROW ================= -->
    <LinearLayout
        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:orientation="horizontal"

        android:weightSum="5"

        android:paddingHorizontal="6dp">

        <!-- 💸 EXPENSE -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="170dp"
            android:layout_height="110dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:strokeColor="#E5E7EB"
            app:strokeWidth="2dp">

            <LinearLayout
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:text="Expense"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

                <TextView
                    android:text="Stock purchase"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="2dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvExpense"
                    android:text="₹0"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_expense_badge"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 💰 REVENUE -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="170dp"
            android:layout_height="110dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:strokeColor="#BFDBFE"
            app:strokeWidth="2dp">

            <LinearLayout
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:text="Revenue"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

                <TextView
                    android:text="Sales income"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="2dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvRevenue"
                    android:text="₹0"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_revenue_badge"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 📦 COST -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="170dp"
            android:layout_height="110dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:strokeColor="#FED7AA"
            app:strokeWidth="2dp">

            <LinearLayout
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:text="Cost"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

                <TextView
                    android:text="Cost of sold items"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="2dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvCost"
                    android:text="₹0"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_cost_badge"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ⚠️ LOSS -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="170dp"
            android:layout_height="110dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:strokeColor="#FECACA"
            app:strokeWidth="2dp">

            <LinearLayout
                android:padding="14dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:text="Loss"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

                <TextView
                    android:text="Damaged / expired"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="2dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvLoss"
                    android:text="₹0"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_loss_badge"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 🚀 NET PROFIT -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="180dp"
            android:layout_height="110dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="8dp"
            app:strokeColor="#BBF7D0"
            app:cardBackgroundColor="#ECFDF5"
            app:strokeWidth="2dp">

            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:text="Net Profit"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#065F46"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

                <TextView
                    android:text="Final earnings"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="2dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvNetProfit"
                    android:text="₹0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- ================= PRODUCT LIST ================= -->

    <androidx.recyclerview.widget.RecyclerView

        android:id="@+id/rvProducts"

        android:layout_width="match_parent"

        android:layout_height="0dp"

        android:layout_weight="1"

        android:padding="10dp"/>

    <!-- ================= BOTTOM ACTION BAR ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:elevation="6dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrint"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Print Report"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:cornerRadius="14dp"
            app:backgroundTint="#3B82F6"
            app:rippleColor="#33FFFFFF"
            app:icon="@drawable/ic_print"
            app:iconGravity="textStart"
            app:iconPadding="8dp"/>
    </LinearLayout>

</LinearLayout>