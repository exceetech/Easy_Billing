<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="9dp"
    android:orientation="horizontal"
    android:background="@drawable/bg_imp_card"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:padding="13dp">

    <ImageView
        android:id="@+id/ivInsightIcon"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="@drawable/bg_ai_icon"
        android:padding="8dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_kpi_alert"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="11dp">

        <TextView
            android:id="@+id/tvInsightTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Title"
            android:textColor="#1A1A18"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvInsightDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Description"
            android:textColor="#6E6A60"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.3"
            android:maxLines="3"
            android:ellipsize="end" />

        <LinearLayout
            android:id="@+id/rowInsightAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="9dp">
            <TextView
                android:id="@+id/tvInsightAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Review"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#A32D2D" />
            <ImageView
                android:id="@+id/ivInsightArrow"
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:layout_marginStart="3dp"
                android:src="@drawable/ic_arrow_forward"
                app:tint="#A32D2D"
                android:contentDescription="@null" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
