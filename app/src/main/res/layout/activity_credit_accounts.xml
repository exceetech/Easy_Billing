<?xml version="1.0" encoding="utf-8"?>
<!--
    Credit accounts (khata) — champagne theme, same language as the
    import-services list: eyebrow + serif accent header, white cards, serif
    numerals, green CTA.

    The four stacked summary cards became one. Net position leads, with due and
    advance as tinted tiles under it; the per-status counts moved into the
    filter chips, which is what the fourth card existed to show.

    Filtering used to be hidden behind tapping those cards, with a dimming
    effect as the only feedback. Chips make it visible what can be filtered and
    which filter is on.

    Ids bound by CreditAccountsActivity: toolbar, etSearchCustomer,
    tvNetBalance, tvNetCaption, tvTotalDue, tvDueCount, tvTotalAdvance,
    tvAdvanceCount, chipAll, chipDue, chipAdvance, chipSettled, rvCustomers,
    btnAddCustomer.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3ECDD">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        android:elevation="0dp"
        app:title=""
        app:titleTextColor="#1A1A18"
        app:navigationIconTint="#1A1A18" />

    <!-- ===================== HEADER ===================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KHATA"
            android:textColor="#B8895A"
            android:textSize="10sp"
            android:letterSpacing="0.16"
            android:fontFamily="@font/googlesans_semibold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="1dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Credit"
                android:textColor="#1A1A18"
                android:textSize="21sp"
                android:letterSpacing="-0.02"
                android:fontFamily="@font/googlesans_bold"
                android:includeFontPadding="false"
                android:accessibilityHeading="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="accounts"
                android:textColor="#0F6E56"
                android:textSize="21sp"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:includeFontPadding="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===================== SUMMARY ===================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_inv_value_card"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Net position"
            android:textSize="11sp"
            android:textColor="#9A8F79" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginTop="2dp"
            android:baselineAligned="false">

            <TextView
                android:id="@+id/tvNetBalance"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textSize="30sp"
                android:textColor="#1A1A18"
                android:fontFamily="serif"
                android:includeFontPadding="false"
                android:singleLine="true"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="20sp"
                app:autoSizeMaxTextSize="30sp" />

            <TextView
                android:id="@+id/tvNetCaption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="4dp"
                android:text="owed to you"
                android:textSize="11sp"
                android:textColor="#B23A3A" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_credit_tile_red"
                android:padding="10dp">
                <TextView
                    android:id="@+id/tvTotalDue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textSize="16sp"
                    android:textColor="#791F1F"
                    android:singleLine="true"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="11sp"
                    app:autoSizeMaxTextSize="16sp" />
                <TextView
                    android:id="@+id/tvDueCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="Due"
                    android:textSize="9.5sp"
                    android:textColor="#A32D2D" />
            </LinearLayout>

            <View android:layout_width="8dp" android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_credit_tile_teal"
                android:padding="10dp">
                <TextView
                    android:id="@+id/tvTotalAdvance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textSize="16sp"
                    android:textColor="#085041"
                    android:singleLine="true"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="11sp"
                    app:autoSizeMaxTextSize="16sp" />
                <TextView
                    android:id="@+id/tvAdvanceCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="Advance"
                    android:textSize="9.5sp"
                    android:textColor="#0F6E56" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ===================== SEARCH ===================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_imp_filter"
        android:paddingHorizontal="12dp">

        <ImageView
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:src="@drawable/ic_search"
            app:tint="#B8895A"
            android:contentDescription="@null" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearchCustomer"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:hint="Search name or phone"
            android:textColorHint="#A99E88"
            android:textColor="#1A1A18"
            android:textSize="12.5sp"
            android:singleLine="true"
            android:paddingStart="8dp"
            android:importantForAutofill="no"
            android:inputType="text" />
    </LinearLayout>

    <!-- ===================== FILTER CHIPS ===================== -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Chip text carries its own count — set in updateSummary. -->
            <TextView android:id="@+id/chipAll"      style="@style/CreditChip" android:text="All" />
            <View android:layout_width="7dp" android:layout_height="1dp" />
            <TextView android:id="@+id/chipDue"      style="@style/CreditChip" android:text="Due" />
            <View android:layout_width="7dp" android:layout_height="1dp" />
            <TextView android:id="@+id/chipAdvance"  style="@style/CreditChip" android:text="Advance" />
            <View android:layout_width="7dp" android:layout_height="1dp" />
            <TextView android:id="@+id/chipSettled"  style="@style/CreditChip" android:text="Settled" />
        </LinearLayout>
    </HorizontalScrollView>

    <!--
        One card holding hairline-separated rows, like the import-services
        ledger. clipToOutline is set in code so the first and last row follow
        the card's corner radius.
    -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCustomers"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_inv_value_card"
            android:clipToPadding="false"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/tvCustomersEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="24dp"
            android:text="No customers found"
            android:textSize="14sp"
            android:textColor="#8A8272"
            android:visibility="gone" />
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddCustomer"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_login_cta_green"
        app:backgroundTint="@null"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="Add customer"
        android:textAllCaps="false"
        android:textSize="13.5sp"
        android:textColor="@android:color/white"
        android:fontFamily="@font/googlesans_semibold"
        app:icon="@drawable/ic_lc_user_plus"
        app:iconTint="@android:color/white"
        app:iconSize="17dp"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        android:gravity="center"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:includeFontPadding="false"
        android:lineSpacingExtra="0dp"
        android:stateListAnimator="@null"
        app:cornerRadius="14dp"
        app:rippleColor="#33FFFFFF" />

</LinearLayout>
