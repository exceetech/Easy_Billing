<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_card"
    android:paddingHorizontal="26dp"
    android:paddingTop="20dp"
    android:paddingBottom="22dp">

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <View android:layout_width="3dp" android:layout_height="12dp" android:background="#D4A574"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="LINE DISCOUNT"
                    android:textColor="#8A6526"
                    android:textSize="10sp"
                    android:letterSpacing="0.14"
                    android:fontFamily="@font/googlesans_semibold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvDiscProduct"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Item"
                android:textColor="#1A1A18"
                android:textSize="19sp"
                android:fontFamily="serif"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvDiscLineTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="₹0"
                android:textColor="#9A8F79"
                android:textSize="12sp"/>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/btnCloseDiscount"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_disc_close_circle"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lc_x"
                app:tint="#8A8272"
                android:contentDescription="Close"/>
        </FrameLayout>
    </LinearLayout>

    <!-- % / ₹ toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_inv_pay_seg_track"
        android:padding="4dp"
        android:layout_marginTop="16dp">
        <TextView
            android:id="@+id/tvModePercent"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:text="Percent %"
            android:textSize="13sp"
            android:fontFamily="@font/googlesans_semibold"/>
        <TextView
            android:id="@+id/tvModeAmount"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:text="Amount ₹"
            android:textSize="13sp"
            android:fontFamily="@font/googlesans_semibold"/>
    </LinearLayout>

    <!-- Input: icon + centered number + unit -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_disc_input">

        <!-- Tag icon pinned to the left of the box -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_lc_tag"
            app:tint="#0F6E56"
            android:contentDescription="@null"/>

        <!-- Centered value group: [₹ prefix] number [% suffix] -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvUnitPrefix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="₹"
                android:textColor="#0F6E56"
                android:textSize="26sp"
                android:fontFamily="@font/googlesans_bold"
                android:includeFontPadding="false"
                android:visibility="gone"/>

            <EditText
                android:id="@+id/etDiscountAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="42dp"
                android:background="@null"
                android:gravity="center"
                android:hint="0"
                android:textColorHint="#B0A48C"
                android:textColor="#1A1A18"
                android:textSize="31sp"
                android:fontFamily="@font/googlesans_bold"
                android:inputType="numberDecimal"
                android:textCursorDrawable="@drawable/cursor_thin"
                android:includeFontPadding="false"/>

            <TextView
                android:id="@+id/tvUnitSuffix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="%"
                android:textColor="#0F6E56"
                android:textSize="26sp"
                android:fontFamily="@font/googlesans_bold"
                android:includeFontPadding="false"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Quick presets (even 4-up) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:baselineAligned="false">
        <TextView android:id="@+id/tvPreset1"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:gravity="center" android:paddingVertical="8dp" android:text="5%"
            android:textSize="12sp" android:textColor="#8A8272" android:fontFamily="@font/googlesans_semibold"
            android:background="@drawable/bg_inv_pay_gold_unselected" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/tvPreset2"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:gravity="center" android:paddingVertical="8dp" android:text="10%"
            android:textSize="12sp" android:textColor="#8A8272" android:fontFamily="@font/googlesans_semibold"
            android:background="@drawable/bg_inv_pay_gold_unselected" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/tvPreset3"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:gravity="center" android:paddingVertical="8dp" android:text="15%"
            android:textSize="12sp" android:textColor="#8A8272" android:fontFamily="@font/googlesans_semibold"
            android:background="@drawable/bg_inv_pay_gold_unselected" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/tvPreset4"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:gravity="center" android:paddingVertical="8dp" android:text="20%"
            android:textSize="12sp" android:textColor="#8A8272" android:fontFamily="@font/googlesans_semibold"
            android:background="@drawable/bg_inv_pay_gold_unselected" android:clickable="true" android:focusable="true"/>
    </LinearLayout>

    <!-- Live preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_disc_preview"
        android:paddingHorizontal="15dp"
        android:paddingVertical="13dp"
        android:layout_marginTop="14dp"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="NEW PRICE" android:textColor="#5E8A6E" android:textSize="10sp"
                android:letterSpacing="0.06" android:fontFamily="@font/googlesans_semibold"/>
            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="3dp">
                <TextView android:id="@+id/tvDiscNew"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="₹0" android:textColor="#0F6E56" android:textSize="19sp"
                    android:fontFamily="@font/googlesans_bold" android:includeFontPadding="false"/>
                <TextView android:id="@+id/tvDiscOrig"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:text="₹0" android:textColor="#A99E88" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="YOU SAVE" android:textColor="#5E8A6E" android:textSize="10sp"
                android:letterSpacing="0.06" android:fontFamily="@font/googlesans_semibold"/>
            <TextView android:id="@+id/tvDiscSave"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="₹0 · 0%" android:textColor="#1A3D2A" android:textSize="16sp"
                android:fontFamily="@font/googlesans_bold" android:includeFontPadding="false"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoveDiscount"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="54dp"
            android:layout_marginEnd="10dp"
            android:text="Remove"
            android:textAllCaps="false"
            android:textSize="13.5sp"
            android:textStyle="bold"
            android:textColor="#9A2E2E"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:background="@drawable/bg_inv_action_close"
            android:stateListAnimator="@null"
            app:icon="@drawable/ic_lc_trash"
            app:iconTint="#9A2E2E"
            app:iconSize="17dp"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:cornerRadius="13dp"
            app:backgroundTint="@null"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyDiscount"
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="54dp"
            android:text="Apply discount"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:background="@drawable/bg_login_cta_green"
            android:stateListAnimator="@null"
            app:icon="@drawable/ic_lc_check"
            app:iconTint="#FFFFFF"
            app:iconSize="18dp"
            app:iconGravity="textStart"
            app:iconPadding="7dp"
            app:cornerRadius="13dp"
            app:backgroundTint="@null"/>
    </LinearLayout>

</LinearLayout>
