<?xml version="1.0" encoding="utf-8"?>
<!--
    Import of services — GSTR-2 list.

    Champagne theme. Status is the organising principle here rather than a
    decoration: a record the server refused will never sync on its own, so it
    carries a red edge stripe and a worded badge, and sorts to the top. A dot
    in the corner is not enough for something that needs a person to act.

    The KPI row deliberately uses tinted fills from the theme palette instead
    of the old saturated blue / green / amber blocks, which fought the
    champagne background.

    Ids bound by ImportServicesActivity: toolbar, tvHeroCount, tvKpiTaxable,
    layoutItcChip, tvKpiIgst, tvKpiItc, tvKpiUnsynced, etSearch, btnFyFilter,
    tvFyLabel, rvImportServices, layoutEmpty, progressBar, fabAdd.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3ECDD">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ===================== TOOLBAR ===================== -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            android:elevation="0dp"
            app:title=""
            app:titleTextColor="#1A1A18"
            app:navigationIconTint="#1A1A18" />

        <!-- Eyebrow + serif accent title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GSTR-2"
                android:textColor="#B8895A"
                android:textSize="10sp"
                android:letterSpacing="0.16"
                android:fontFamily="@font/googlesans_semibold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="1dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Import of"
                    android:textColor="#1A1A18"
                    android:textSize="21sp"
                    android:letterSpacing="-0.02"
                    android:fontFamily="@font/googlesans_bold"
                    android:includeFontPadding="false"
                    android:accessibilityHeading="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="services"
                    android:textColor="#0F6E56"
                    android:textSize="21sp"
                    android:fontFamily="serif"
                    android:textStyle="italic"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===================== SUMMARY CARD ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_inv_value_card"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total taxable value"
                        android:textSize="11sp"
                        android:textColor="#9A8F79" />

                    <TextView
                        android:id="@+id/tvKpiTaxable"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="₹6,40,000"
                        android:textSize="30sp"
                        android:textColor="#1A1A18"
                        android:fontFamily="serif"
                        android:includeFontPadding="false"
                        android:singleLine="true"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="20sp"
                        app:autoSizeMaxTextSize="30sp" />

                    <TextView
                        android:id="@+id/tvHeroCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="14 records · FY 25–26"
                        android:textSize="11sp"
                        android:textColor="#8A8272"
                        android:singleLine="true"
                        android:ellipsize="end" />
                </LinearLayout>

                <TextView
                    android:id="@+id/layoutItcChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_imp_chip_ready"
                    android:paddingHorizontal="9dp"
                    android:paddingVertical="5dp"
                    android:text="ITC ready"
                    android:textSize="10sp"
                    android:textColor="#085041"
                    android:fontFamily="@font/googlesans_semibold" />
            </LinearLayout>

            <!-- Tinted KPI tiles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_imp_tile_champagne"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="9dp">
                    <TextView
                        android:id="@+id/tvKpiIgst"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="₹1,15,200"
                        android:textSize="15sp"
                        android:textColor="#1A1A18"
                        android:singleLine="true"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="11sp"
                        app:autoSizeMaxTextSize="15sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="IGST paid"
                        android:textSize="9.5sp"
                        android:textColor="#8A8272" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_imp_tile_teal"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="9dp">
                    <TextView
                        android:id="@+id/tvKpiItc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="₹1,12,800"
                        android:textSize="15sp"
                        android:textColor="#085041"
                        android:singleLine="true"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="11sp"
                        app:autoSizeMaxTextSize="15sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="ITC availed"
                        android:textSize="9.5sp"
                        android:textColor="#0F6E56" />
                </LinearLayout>

                <!--
                    "Needs fixing", not "Unsynced". The old tile counted queued
                    and refused records as one number, but queued resolves
                    itself and refused never will.
                -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_imp_tile_red"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="9dp">
                    <TextView
                        android:id="@+id/tvKpiUnsynced"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2"
                        android:textSize="15sp"
                        android:textColor="#791F1F"
                        android:singleLine="true" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="Needs fixing"
                        android:textSize="9.5sp"
                        android:textColor="#A32D2D" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ===================== SEARCH + FY =====================
             Hidden while there is nothing to filter — controls that can't do
             anything are noise on an empty screen. -->
        <LinearLayout
            android:id="@+id/layoutFilters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_imp_filter"
                android:paddingHorizontal="12dp">
                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_search"
                    app:tint="#B8895A"
                    android:contentDescription="@null" />
                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Search invoice number"
                    android:textColorHint="#A99E88"
                    android:textColor="#1A1A18"
                    android:textSize="12.5sp"
                    android:singleLine="true"
                    android:paddingStart="8dp"
                    android:importantForAutofill="no"
                    android:inputType="text" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnFyFilter"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_imp_filter"
                android:paddingHorizontal="12dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvFyLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FY 25–26"
                    android:textSize="12sp"
                    android:textColor="#1A1A18" />
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="5dp"
                    android:src="@drawable/ic_chevron_down"
                    app:tint="#9A8F79"
                    android:contentDescription="@null" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/tvRecordsLabel"
            android:paddingHorizontal="18dp"
            android:paddingBottom="6dp"
            android:text="RECORDS"
            android:textSize="9.5sp"
            android:letterSpacing="0.14"
            android:textColor="#A99E88"
            android:fontFamily="@font/googlesans_semibold" />

        <!--
            One card holding hairline-separated rows rather than a stack of
            floating cards — it reads as a ledger, which is what it is.
        -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvImportServices"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_inv_value_card"
            android:clipToPadding="false"
            android:paddingBottom="4dp" />

        <!-- ===================== EMPTY STATE =====================
             In the records card's own place, not floating over the middle of
             the screen. A centred card on top of other cards is what made the
             old one read as bolted on: the summary card and the RECORDS label
             were still visible behind it. -->
        <ScrollView
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_inv_value_card"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingHorizontal="26dp"
                android:paddingTop="30dp"
                android:paddingBottom="26dp">

                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_imp_empty_circle">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_file_import"
                        app:tint="#B8895A"
                        android:contentDescription="@null" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nothing imported"
                        android:textSize="19sp"
                        android:textColor="#1A1A18"
                        android:fontFamily="@font/googlesans_bold"
                        android:includeFontPadding="false" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="yet"
                        android:textSize="19sp"
                        android:textColor="#0F6E56"
                        android:fontFamily="serif"
                        android:textStyle="italic"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:gravity="center"
                    android:text="Record invoices from overseas suppliers here — consultancy, software licences, freight — so the IGST you pay under reverse charge shows up in your GSTR-2."
                    android:textSize="12.5sp"
                    android:textColor="#8A8272"
                    android:lineSpacingExtra="3dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp"
                    android:background="#F1EBDD" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="11dp">
                    <ImageView
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:layout_marginTop="1dp"
                        android:src="@drawable/ic_receipt"
                        app:tint="#B8895A"
                        android:contentDescription="@null" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Keep the supplier invoice"
                            android:textSize="12sp"
                            android:textColor="#1A1A18" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="Invoice number, date and value"
                            android:textSize="11sp"
                            android:textColor="#9A8F79" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:layout_marginTop="1dp"
                        android:src="@drawable/ic_lc_percent"
                        app:tint="#B8895A"
                        android:contentDescription="@null" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IGST is worked out for you"
                            android:textSize="12sp"
                            android:textColor="#1A1A18" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="Enter the rate and taxable value"
                            android:textSize="11sp"
                            android:textColor="#9A8F79" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabAdd"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_login_cta_green"
            app:backgroundTint="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Add record"
            android:textAllCaps="false"
            android:textSize="13.5sp"
            android:textColor="@android:color/white"
            android:fontFamily="@font/googlesans_semibold"
            app:icon="@drawable/ic_lc_file_plus"
            app:iconTint="@android:color/white"
            app:iconSize="17dp"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            android:gravity="center"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:includeFontPadding="false"
            android:lineSpacingExtra="0dp"
            android:stateListAnimator="@null"
            app:cornerRadius="14dp"
            app:rippleColor="#33FFFFFF" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>
