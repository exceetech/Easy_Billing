<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3F4F6">

    <!-- HEADER CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#2F2E2F">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvHeaderSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Raise Debit Note"
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true"/>

            <TextView
                android:id="@+id/tvSupplierName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:text="Supplier"/>

            <View
                android:id="@+id/vHeaderDivider"
                android:layout_width="32dp"
                android:layout_height="2dp"
                android:layout_marginVertical="6dp"
                android:background="#DC2626"/>

            <TextView
                android:id="@+id/tvInvoiceRef"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:text="Invoice #—"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Main Content Area (Scrollable) -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Section label -->
            <TextView
                android:id="@+id/tvSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:text="Select items &amp; quantities to return"/>

            <!-- Items list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvReturnItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:paddingBottom="8dp"/>

            <!-- GSTR-2 Details Expandable Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvGstr2Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header Row to toggle expand/collapse -->
                    <LinearLayout
                        android:id="@+id/llGstr2Header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:background="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="GSTR-2 Debit Note Details"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#374151"/>

                        <ImageView
                            android:id="@+id/ivGstr2Arrow"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="#6B7280"/>
                    </LinearLayout>

                    <!-- Expandable Form Content -->
                    <LinearLayout
                        android:id="@+id/llGstr2Details"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone">

                        <!-- Pre-GST Toggle Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Pre GST Document"
                                android:textSize="13sp"
                                android:textColor="#374151"/>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/swPreGst"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <!-- Document Type Dropdown -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilDocumentType"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Document Type">

                            <AutoCompleteTextView
                                android:id="@+id/actvDocumentType"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Reason For Issuing Document Dropdown -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilReason"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Reason for Issuing Document">

                            <AutoCompleteTextView
                                android:id="@+id/actvReason"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Note/Refund Voucher Value -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilVoucherValue"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Note / Refund Voucher Value">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etVoucherValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Rate % -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilRate"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Rate (%)">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Eligibility For ITC Dropdown -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilEligibility"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Eligibility for ITC">

                            <AutoCompleteTextView
                                android:id="@+id/actvEligibility"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Availed ITC Integrated Tax -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilAvailedItcIntegrated"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Availed ITC Integrated Tax">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAvailedItcIntegrated"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Availed ITC Central Tax -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilAvailedItcCentral"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Availed ITC Central Tax">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAvailedItcCentral"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Availed ITC State Tax -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilAvailedItcState"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Availed ITC State/UT Tax">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAvailedItcState"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Availed ITC Cess -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilAvailedItcCess"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Availed ITC Cess">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAvailedItcCess"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Invoice Type Dropdown -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilInvoiceType"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Invoice Type">

                            <AutoCompleteTextView
                                android:id="@+id/actvInvoiceType"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Place Of Supply Code Dropdown -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilPlaceOfSupplyCode"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Place of Supply (State Code)">

                            <AutoCompleteTextView
                                android:id="@+id/actvPlaceOfSupplyCode"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"/>
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM SUMMARY + CONFIRM CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FFFBFF"
        app:strokeColor="#E5E7EB"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Total debit value -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTotalDebitLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Debit Value"
                    android:textSize="14sp"
                    android:textColor="#374151"/>

                <TextView
                    android:id="@+id/tvTotalDebitValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0.00"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#DC2626"/>

            </LinearLayout>

            <!-- GST reclaim row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ITC Reclaim (GST)"
                    android:textSize="13sp"
                    android:textColor="#6B7280"/>

                <TextView
                    android:id="@+id/tvItcReclaim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0.00"
                    android:textSize="13sp"
                    android:textColor="#6B7280"/>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#E5E7EB"/>

            <!-- Confirm button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmReturn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Confirm &amp; Issue Debit Note"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="15sp"
                app:backgroundTint="#DC2626"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_check_circle"
                app:iconPadding="8dp"
                app:iconGravity="textStart"
                app:iconTint="#FFFFFF"/>

            <!-- Cancel button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelReturn"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:text="Cancel"
                android:textColor="#6B7280"
                android:textAllCaps="false"
                app:cornerRadius="14dp"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
