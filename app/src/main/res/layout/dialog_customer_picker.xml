<?xml version="1.0" encoding="utf-8"?>
<!--
    Credit-account picker sheet — champagne theme.
    Shared by InvoiceActivity.handleCreditFlow() and CreditAccountPicker
    (Record a purchase / Inventory), so restyling here covers every screen.

    Ids bound by callers are unchanged: etSearchCustomer, rvCustomers,
    btnNewCustomer.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_picker_sheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:focusableInTouchMode="true"
    android:focusable="true">

    <!-- Drag handle -->
    <View
        android:layout_width="38dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_picker_handle"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="18dp"
        android:paddingBottom="12dp">

        <View
            android:layout_width="3dp"
            android:layout_height="28dp"
            android:layout_marginEnd="11dp"
            android:background="@drawable/bg_mp_title_tick"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ON CREDIT"
                android:textColor="#B8895A"
                android:textSize="10sp"
                android:letterSpacing="0.16"
                android:fontFamily="@font/googlesans_semibold"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="1dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select"
                    android:textColor="#1A1A18"
                    android:textSize="19sp"
                    android:letterSpacing="-0.02"
                    android:fontFamily="@font/googlesans_bold"
                    android:includeFontPadding="false"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="account"
                    android:textColor="#0F6E56"
                    android:textSize="19sp"
                    android:fontFamily="serif"
                    android:textStyle="italic"
                    android:includeFontPadding="false"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvAccountCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#9A8F79"
            android:textSize="11sp"
            android:fontFamily="@font/googlesans_medium"/>
    </LinearLayout>

    <!-- Glass search field -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_glass_input"
        android:paddingHorizontal="13dp">

        <ImageView
            android:layout_width="17dp"
            android:layout_height="17dp"
            android:layout_marginEnd="10dp"
            android:src="@drawable/ic_search"
            app:tint="#B8895A"
            android:contentDescription="@null"/>

        <EditText
            android:id="@+id/etSearchCustomer"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@null"
            android:hint="Search name or phone"
            android:textColor="#1A1A18"
            android:textColorHint="#A99E88"
            android:inputType="text"
            android:singleLine="true"
            android:textSize="13.5sp"/>
    </LinearLayout>

    <!-- List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCustomers"
        android:layout_width="match_parent"
        android:layout_height="296dp"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"/>

    <!-- New account -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="18dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewCustomer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="+  New credit account"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#0F6E56"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:background="@drawable/bg_inv_add_dashed"
            android:stateListAnimator="@null"
            app:cornerRadius="12dp"
            app:backgroundTint="@null"
            app:rippleColor="#220F6E56"/>
    </LinearLayout>
</LinearLayout>
