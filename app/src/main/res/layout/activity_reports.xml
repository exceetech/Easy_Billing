<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA">

    <!-- TOOLBAR -->

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        app:title="Analytics Dashboard"
        app:titleCentered="true"
        android:elevation="0dp"
        android:background="@android:color/transparent"
        app:titleTextColor="@color/textPrimary"
        app:navigationIconTint="@color/textPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- DATE FILTER -->

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipDateFilter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:singleSelection="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipToday"
            android:text="Today"
            android:checked="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipWeek"
            android:text="Week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipMonth"
            android:text="Month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipYear"
            android:text="Year"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipCustom"
            android:text="Custom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </com.google.android.material.chip.ChipGroup>


    <!-- MAIN CONTENT -->

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/chipDateFilter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- KPI CARDS -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- ================= REVENUE ================= -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:layout_height="160dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="4dp"
                    android:backgroundTint="#EEF2FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- TOP ROW -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">

                            <TextView
                                android:text="Revenue"
                                android:textColor="#6366F1"
                                android:textSize="12sp"
                                android:layout_weight="1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <ImageView
                                android:src="@drawable/ic_money"
                                android:layout_width="18dp"
                                android:layout_height="18dp"/>
                        </LinearLayout>

                        <!-- VALUE -->
                        <TextView
                            android:id="@+id/tvRevenue"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <!-- GROWTH -->
                        <TextView
                            android:id="@+id/tvRevenueGrowth"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <!-- MINI GRAPH -->
                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartRevenueMini"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ================= BILLS ================= -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:layout_height="160dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="4dp"
                    android:backgroundTint="#ECFEFF">

                    <LinearLayout
                        android:padding="14dp"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:text="Bills"
                                android:textColor="#0891B2"
                                android:textSize="12sp"
                                android:layout_weight="1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <ImageView
                                android:src="@drawable/ic_receipt"
                                android:layout_width="18dp"
                                android:layout_height="18dp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvBills"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/tvBillsGrowth"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartBillsMini"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ================= AVG ================= -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:layout_height="160dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="4dp"
                    android:backgroundTint="#FFF7ED">

                    <LinearLayout
                        android:padding="14dp"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:text="Avg Bill"
                                android:textColor="#EA580C"
                                android:textSize="12sp"
                                android:layout_weight="1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <ImageView
                                android:src="@drawable/ic_calculations"
                                android:layout_width="18dp"
                                android:layout_height="18dp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvAverage"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/tvAverageGrowth"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartAvgMini"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>


            <!-- SALES TREND -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp">

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartSalesTrend"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </com.google.android.material.card.MaterialCardView>


            <!-- PEAK HOURS -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp">

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/chartPeakHours"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </com.google.android.material.card.MaterialCardView>


            <!-- DAILY SALES -->

            <TextView
                android:text="Daily Sales"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDaily"
                android:layout_width="match_parent"
                android:layout_height="200dp"/>


            <!-- MONTHLY SALES -->

            <TextView
                android:text="Monthly Sales"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMonthly"
                android:layout_width="match_parent"
                android:layout_height="200dp"/>


            <!-- TOP PRODUCTS -->

            <TextView
                android:text="Top Products"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProducts"
                android:layout_width="match_parent"
                android:layout_height="200dp"/>


            <!-- PEAK HOURS TABLE -->

            <TextView
                android:text="Peak Hours"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPeakHours"
                android:layout_width="match_parent"
                android:layout_height="200dp"/>

            <!-- SEND EMAIL REPORT -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendReport"
                android:text="Send Report to Email"
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>