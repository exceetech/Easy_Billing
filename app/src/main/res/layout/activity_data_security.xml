<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            android:elevation="0dp"
            app:titleTextColor="?attr/colorOnSurface"
            app:navigationIconTint="?attr/colorOnSurface" />

        <!-- Title -->
        <TextView
            android:text="@string/data_and_security"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="28dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- 🟢 LOW RISK -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChangePassword"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/change_login_password"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="16dp"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_lock"
            app:iconPadding="16dp"
            app:iconTint="@android:color/white"
            app:backgroundTint="#2E7D32" />

        <!-- 🟡 MEDIUM RISK -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearBills"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/clear_all_bills"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="16dp"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_clear"
            app:iconPadding="16dp"
            app:iconTint="@android:color/black"
            app:backgroundTint="#FBC02D" />

        <!-- 🟠 HIGH RISK -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFactoryReset"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/factory_reset_app"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_clean"
            app:iconPadding="16dp"
            app:iconTint="@android:color/white"
            app:backgroundTint="#D84315" />

    </LinearLayout>

</ScrollView>