<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="12dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#F1F1F1"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Dynamic Monogram Box -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="16dp">
                
                <View
                    android:id="@+id/viewMonogramBg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_monogram_avatar"/>
                
                <TextView
                    android:id="@+id/tvMonogram"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#18181B"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvUnitPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#71717A"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#18181B"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="serif"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F4F4F5"
            android:layout_marginVertical="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:background="@drawable/bg_stepper_track"
                android:paddingHorizontal="4dp"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btnMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_minus"
                    android:scaleType="center"
                    android:background="@drawable/bg_minus_btn"
                    app:tint="#EF4444"/>

                <TextView
                    android:id="@+id/tvQty"
                    android:layout_width="54dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="#18181B"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginHorizontal="4dp"/>

                <ImageButton
                    android:id="@+id/btnPlus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_plus"
                    android:scaleType="center"
                    android:background="@drawable/bg_plus_btn"
                    app:tint="#00FF88"/>
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/baseline_delete_24"
                android:background="@drawable/bg_delete_btn"
                app:tint="#EF4444"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>