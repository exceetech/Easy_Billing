<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF8F5">

    <!-- Premium Animated Background -->
    <com.example.easy_billing.util.PatternedBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:navigationIconTint="#18181B"
        app:titleTextColor="#18181B"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="48dp">

            <LinearLayout
                android:id="@+id/mainContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                app:layout_constraintWidth_max="400dp"
                app:layout_constraintWidth_percent="0.85"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Scalancer Style Category Header -->
                <LinearLayout
                    android:id="@+id/headerSecurity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/lineSecurity"
                        android:layout_width="24dp"
                        android:layout_height="1dp"
                        android:background="#00FF41"/>

                    <TextView
                        android:id="@+id/tvSecurityUpdate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:letterSpacing="0.25"
                        android:text="SECURITY UPDATE"
                        android:textColor="#71717A"
                        android:textSize="11sp"
                        android:textAllCaps="true"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/imgLogo"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_lock"
                    app:tint="#D4A574"
                    android:layout_marginBottom="24dp"/>

                <!-- Scalancer Style Mixed-Serif Title -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvChangeBase"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Change "
                        android:textSize="34sp"
                        android:textColor="#FFFFFF"
                        android:fontFamily="serif"/>

                    <TextView
                        android:id="@+id/tvChangeAccent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password"
                        android:textSize="34sp"
                        android:textColor="#D4A574"
                        android:fontFamily="serif"
                        android:textStyle="italic"/>
                </LinearLayout>

                <!-- Trademark Elastic Green Line -->
                <View
                    android:id="@+id/wordmarkAccent"
                    android:layout_width="60dp"
                    android:layout_height="2dp"
                    android:layout_marginBottom="16dp"
                    android:background="#00FF41"/>

                <TextView
                    android:id="@+id/tvTagline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create a new strong password."
                    android:textSize="14sp"
                    android:textColor="#71717A"
                    android:layout_marginBottom="32dp"/>

                <!-- New Password Field -->
                <FrameLayout
                    android:id="@+id/newPasswordContainer"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"

                    android:addStatesFromChildren="true"
                    android:focusable="true"
                    android:clickable="true"

                    android:background="@drawable/sel_premium_input">

                    <ImageView
                        android:id="@+id/iconNewPassword"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="18dp"
                        android:src="@drawable/ic_lock"
                        app:tint="#8F9098"/>

                    <EditText
                        android:id="@+id/etNewPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"

                        android:background="@null"
                        android:paddingStart="56dp"
                        android:paddingEnd="18dp"

                        android:hint="New Password"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#71717A"

                        android:textSize="15.5sp"

                        android:inputType="textPassword"
                        android:imeOptions="actionNext"
                        android:singleLine="true"/>
                </FrameLayout>

                <!-- Confirm Password Field -->
                <FrameLayout
                    android:id="@+id/confirmPasswordContainer"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="14dp"

                    android:addStatesFromChildren="true"
                    android:focusable="true"
                    android:clickable="true"

                    android:background="@drawable/sel_premium_input">

                    <ImageView
                        android:id="@+id/iconConfirmPassword"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="18dp"
                        android:src="@drawable/ic_lock"
                        app:tint="#8F9098"/>

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"

                        android:background="@null"
                        android:paddingStart="56dp"
                        android:paddingEnd="18dp"

                        android:hint="Confirm Password"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#71717A"

                        android:textSize="15.5sp"

                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:singleLine="true"/>
                </FrameLayout>

                <!-- Save Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSavePassword"
                    style="@style/PremiumButton"
                    android:layout_width="match_parent"
                    android:layout_marginTop="28dp"
                    android:text="CHANGE PASSWORD"
                    android:stateListAnimator="@animator/button_press_anim"/>

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>