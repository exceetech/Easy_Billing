<?xml version="1.0" encoding="utf-8"?>
<!--
    Purchase line row — same design as the invoice line item
    (item_invoice_premium). Rows sit inside the LINE ITEMS card,
    separated by a hairline (vDivider, hidden on the last row).

    Bound by PurchaseLinesAdapter:
      tvAvatar — product initials
      tvName   — product name (+ muted variant)
      tvMeta   — "20 × ₹460 · GST 5%"
      tvPrice  — invoice value (line total incl. GST)
      tvTax    — "+₹460 tax"  (or "no tax")
      btnRemove — remove the line
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="11dp"
        android:paddingHorizontal="2dp">

        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="BR"
            android:textColor="#0B5544"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_inv_avatar_green"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvName"
                android:text="Basmati rice"
                android:textColor="#18181B"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvMeta"
                android:text="20 × ₹460 · GST 5%"
                android:textColor="#9A8F79"
                android:textSize="10sp"
                android:layout_marginTop="2dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tvPrice"
                android:text="₹9,660"
                android:textColor="#18181B"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvTax"
                android:text="+₹460 tax"
                android:textColor="#0F6E56"
                android:textSize="10sp"
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnRemove"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Remove"
            android:src="@drawable/ic_lc_x"
            app:tint="#C0B49C"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>

    <View
        android:id="@+id/vDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="48dp"
        android:background="#F1E9D9"/>
</LinearLayout>
