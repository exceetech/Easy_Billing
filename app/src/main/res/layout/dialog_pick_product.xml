<?xml version="1.0" encoding="utf-8"?>
<!-- Searchable product picker for adding items to an invoice. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F3ECDD"
    android:padding="18dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add item"
        android:textColor="#18181B"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="serif"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_glass_input">

        <ImageView
            android:layout_width="19dp"
            android:layout_height="19dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="14dp"
            android:src="@drawable/ic_lc_id_card"
            app:tint="#B8895A"
            android:contentDescription="@null"/>

        <EditText
            android:id="@+id/etPickerSearch"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:paddingStart="44dp"
            android:paddingEnd="14dp"
            android:hint="Search products"
            android:textColor="#1A1A18"
            android:textColorHint="#A99E88"
            android:inputType="text"
            android:singleLine="true"
            android:textSize="14sp"/>
    </FrameLayout>

    <ListView
        android:id="@+id/lvPicker"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:layout_marginTop="12dp"
        android:divider="#EEE7D8"
        android:dividerHeight="1dp"/>

    <TextView
        android:id="@+id/tvPickerEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="18dp"
        android:text="No products found"
        android:textColor="#9A8F79"
        android:textSize="13sp"
        android:visibility="gone"/>
</LinearLayout>
