<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- Toolbar -->

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FAFAFA"
        android:elevation="0dp"
        app:navigationIconTint="@color/textPrimary"
        app:titleTextColor="@color/textPrimary"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- LANGUAGE -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLanguage"
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="#EEF2FF"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_language"
                        android:contentDescription="@null"
                        app:tint="#6366F1"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:text="@string/language"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@color/textPrimary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <AutoCompleteTextView
                            android:id="@+id/spLanguage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#6B7280"
                            android:focusable="false"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- REGION -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRegion"
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="#E8F8F5"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_location"
                        android:contentDescription="@null"
                        app:tint="#10B981"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:text="@string/region"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@color/textPrimary"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"/>

                        <AutoCompleteTextView
                            android:id="@+id/spRegion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#6B7280"
                            android:focusable="false"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- CURRENCY -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCurrency"
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="#FFF4E5"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_currency"
                        android:contentDescription="@null"
                        app:tint="#F59E0B"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:text="@string/currency"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@color/textPrimary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <AutoCompleteTextView
                            android:id="@+id/spCurrency"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#6B7280"
                            android:focusable="false"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- SAVE BUTTON -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveLocalization"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:text="@string/save_changes"
                android:visibility="gone"
                style="@style/Widget.Material3.Button"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>