<?xml version="1.0" encoding="utf-8"?>
<!--
    Account options sheet — champagne theme, same skeleton as the supplier and
    credit-account pickers.

    The balance sits in the header because three of the four actions depend on
    it: settle clears it, delete is blocked unless it is zero, and a payment
    reduces it. Showing it saves the user remembering which row they tapped.

    Delete lives on its own card, separated by a real gap rather than only a
    red tint, so it is harder to hit by accident. It is dimmed and unclickable
    while a balance is outstanding — the activity refuses that case anyway, but
    only after the tap, with a toast.

    Ids bound by CreditAccountsActivity.showAccountOptions: tvAvatar,
    tvCustomerName, tvPhone, tvBalance, tvBalanceCaption, optionAdd,
    optionSettle, tvSettleSub, optionView, optionDelete, tvDeleteSub,
    ivDeleteChevron.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_picker_sheet"
    android:paddingTop="10dp"
    android:paddingBottom="18dp">

    <View
        android:layout_width="38dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_picker_handle" />

    <!-- ===================== WHO ===================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="18dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:gravity="center"
            android:text="R"
            android:textSize="17sp"
            android:textColor="#8A8272"
            android:fontFamily="@font/googlesans_semibold"
            android:background="@drawable/bg_credit_avatar"
            android:backgroundTint="#F3ECDD"
            android:includeFontPadding="false" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvCustomerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Customer"
                android:textSize="15sp"
                android:textColor="#1A1A18"
                android:fontFamily="@font/googlesans_medium"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textSize="11.5sp"
                android:textColor="#9A8F79"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textSize="21sp"
                android:textColor="#1A1A18"
                android:fontFamily="serif"
                android:includeFontPadding="false"
                android:singleLine="true" />

            <TextView
                android:id="@+id/tvBalanceCaption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="settled"
                android:textSize="9.5sp"
                android:textColor="#A99E88" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===================== ROUTINE ACTIONS ===================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_inv_value_card">

        <LinearLayout
            android:id="@+id/optionAdd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="15dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="9dp"
                android:src="@drawable/ic_lc_indian_rupee"
                app:tint="#0F6E56"
                android:background="@drawable/bg_credit_action_tile"
                android:backgroundTint="#E1F5EE"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="13dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Record a payment"
                    android:textSize="13.5sp"
                    android:textColor="#1A1A18" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="Reduce what they owe"
                    android:textSize="11sp"
                    android:textColor="#9A8F79" />
            </LinearLayout>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_lc_chevron_right"
                app:tint="#C9BFA8"
                android:contentDescription="@null" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginHorizontal="16dp"
            android:background="#F1EBDD" />

        <LinearLayout
            android:id="@+id/optionSettle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="15dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="9dp"
                android:src="@drawable/ic_lucide_check"
                app:tint="#8A6526"
                android:background="@drawable/bg_credit_action_tile"
                android:backgroundTint="#F3ECDD"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="13dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settle account"
                    android:textSize="13.5sp"
                    android:textColor="#1A1A18" />
                <!--
                    Names the exact amount. The confirmation that follows says
                    only "Clear all dues", which is easy to accept for the
                    wrong customer.
                -->
                <TextView
                    android:id="@+id/tvSettleSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="Clear the balance"
                    android:textSize="11sp"
                    android:textColor="#9A8F79" />
            </LinearLayout>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_lc_chevron_right"
                app:tint="#C9BFA8"
                android:contentDescription="@null" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginHorizontal="16dp"
            android:background="#F1EBDD" />

        <LinearLayout
            android:id="@+id/optionView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="15dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="9dp"
                android:src="@drawable/ic_lc_file_text"
                app:tint="#185FA5"
                android:background="@drawable/bg_credit_action_tile"
                android:backgroundTint="#E6F1FB"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="13dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View transactions"
                    android:textSize="13.5sp"
                    android:textColor="#1A1A18" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="Full history and statement"
                    android:textSize="11sp"
                    android:textColor="#9A8F79" />
            </LinearLayout>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_lc_chevron_right"
                app:tint="#C9BFA8"
                android:contentDescription="@null" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===================== DELETE ===================== -->
    <LinearLayout
        android:id="@+id/optionDelete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:padding="15dp"
        android:background="@drawable/bg_inv_value_card"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="9dp"
            android:src="@drawable/ic_lc_trash"
            app:tint="#B23A3A"
            android:background="@drawable/bg_credit_action_tile"
            android:backgroundTint="#FCEBEB"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="13dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delete account"
                android:textSize="13.5sp"
                android:textColor="#B23A3A" />
            <TextView
                android:id="@+id/tvDeleteSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="Removes them from your list"
                android:textSize="11sp"
                android:textColor="#C0A99A" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivDeleteChevron"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_lc_chevron_right"
            app:tint="#C9BFA8"
            android:contentDescription="@null" />
    </LinearLayout>

</LinearLayout>
