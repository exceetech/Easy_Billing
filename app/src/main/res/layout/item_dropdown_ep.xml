<?xml version="1.0" encoding="utf-8"?>
<!-- Dropdown row for Edit Product's AutoCompleteTextViews (UQC, Supply
     classification, Category) — same look as the Manage Products sort
     popup rows (bg_pos_dropdown container, googlesans_medium, ink text). -->
<TextView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="44dp"
    android:gravity="center_vertical"
    android:paddingHorizontal="12dp"
    android:textColor="#1A1A18"
    android:textSize="14sp"
    android:fontFamily="@font/googlesans_medium"
    android:ellipsize="end"
    android:singleLine="true"
    android:background="?attr/selectableItemBackground"/>
