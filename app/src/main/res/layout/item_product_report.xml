<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"

    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/transparent">

    <!-- 🔥 APPLY BACKGROUND HERE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/transparent">

        <!-- 🔥 TOP ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 🏆 RANK BADGE -->
            <TextView
                android:id="@+id/tvRank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#1"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_rank_chip"/>

            <!-- PRODUCT NAME -->
            <TextView
                android:id="@+id/tvProduct"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Chicken Burger"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#111827"
                android:layout_height="wrap_content"/>

            <!-- STATUS CHIP -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="🔥 Best"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#16A34A"
                android:background="@drawable/bg_growth_chip"/>
        </LinearLayout>

        <!-- 💰 REVENUE -->
        <TextView
            android:id="@+id/tvRevenue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹12,500"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_marginTop="6dp"/>

        <!-- 🧾 QUANTITY -->
        <TextView
            android:id="@+id/tvQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="120 sold"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:layout_marginTop="2dp"/>

        <!-- 📊 PROGRESS -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="10dp"
            android:max="100"
            android:progressDrawable="@drawable/bg_progress_rounded"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>