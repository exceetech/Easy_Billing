<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FAF8F5"
    app:strokeColor="#E4E4E7"
    app:strokeWidth="1dp"
    app:rippleColor="#10D4A574">

    <LinearLayout
        android:id="@+id/productContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ══════ ROW 1: Monogram + Name/Variant + Price ══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Dynamic Monogram Avatar -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="14dp">

                <View
                    android:id="@+id/viewProductMonogramBg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_product_monogram"/>

                <TextView
                    android:id="@+id/tvProductMonogram"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"/>
            </FrameLayout>

            <!-- Name + Variant + Translation stacked -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Name row with inline variant chip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvProductName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#18181B"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:lineSpacingExtra="2dp"/>

                    <!-- Variant chip: warm champagne pill -->
                    <TextView
                        android:id="@+id/tvVariantName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#92400E"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:background="@drawable/bg_product_variant_chip"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- Translated name -->
                <TextView
                    android:id="@+id/tvTranslatedName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="12sp"
                    android:textColor="#A1A1AA"
                    android:visibility="gone"/>

                <!-- Low stock badge: inline -->
                <TextView
                    android:id="@+id/tvLowStockBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="⚠ Low stock"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#92400E"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/bg_badge_warning"
                    android:letterSpacing="0.02"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══════ HAIRLINE ══════ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F4F4F5"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="12dp"/>

        <!-- ══════ ROW 2: Price badge + Unit + Stock info ══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Price badge: cream pill with warm border -->
            <TextView
                android:id="@+id/tvProductPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#18181B"
                android:background="@drawable/bg_product_price"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:maxLines="1"/>

            <!-- Unit label -->
            <TextView
                android:id="@+id/tvProductUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textSize="12sp"
                android:textColor="#A1A1AA"/>

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <!-- Stock status: dot + chip -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/viewStockDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_stock_dot"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvStock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:background="@drawable/bg_stock_chip"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Out of Stock overlay -->
    <FrameLayout
        android:id="@+id/flOutOfStockOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55FFFFFF"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:alpha="0.7"
                android:src="@drawable/ic_out_of_stock"/>
        </LinearLayout>
    </FrameLayout>

</com.google.android.material.card.MaterialCardView>