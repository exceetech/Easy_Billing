<?xml version="1.0" encoding="utf-8"?>

<!--
  Sales — redesigned (bar-chart layout).
  NestedScrollView > white card >
    header (Sales + period chip) · Daily/Monthly toggle · total + growth delta
    · legend · bar chart · 2 metric cards · breakdown list
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1EEE9">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardPreventCornerOverlap="true"
        app:cardBackgroundColor="#FFFFFF">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="22dp"
            android:paddingBottom="110dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sales"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#14161A"/>

                <TextView
                    android:id="@+id/tvPeriodChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This week"
                    android:textSize="13sp"
                    android:textColor="#1B3A8A"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>
            </LinearLayout>

            <!-- Daily / Monthly toggle -->
            <LinearLayout
                android:id="@+id/segContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="3dp"
                android:layout_marginBottom="18dp">

                <TextView
                    android:id="@+id/segDaily"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Daily"
                    android:gravity="center"
                    android:paddingVertical="7dp"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/segMonthly"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Monthly"
                    android:gravity="center"
                    android:paddingVertical="7dp"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Total revenue + growth delta -->
            <TextView
                android:id="@+id/tvTotalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total revenue"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="2dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/tvTotalValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="#14161A"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvDelta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Legend -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_sales_fill"
                    android:layout_marginEnd="5dp"/>

                <TextView
                    android:id="@+id/tvLegendMain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily revenue"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginEnd="16dp"/>

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_sales_fill_best"
                    android:layout_marginEnd="5dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Best day"
                    android:id="@+id/tvLegendBest"
                    android:textSize="12sp"
                    android:textColor="#6B7280"/>
            </LinearLayout>

            <!-- Bar chart -->
            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChart"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginBottom="18dp"/>

            <!-- Metric cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="18dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F1EEE9">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:id="@+id/tvBestLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Best day"
                            android:textSize="12sp"
                            android:textColor="#6B7280"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvBestValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#14161A"/>

                        <TextView
                            android:id="@+id/tvBestSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="12sp"
                            android:textColor="#9AA0A8"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F1EEE9">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:id="@+id/tvAvgLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Avg / day"
                            android:textSize="12sp"
                            android:textColor="#6B7280"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvAvgValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#14161A"/>

                        <TextView
                            android:id="@+id/tvAvgSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="12sp"
                            android:textColor="#9AA0A8"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Breakdown list -->
            <TextView
                android:id="@+id/tvBreakdownLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily breakdown"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="2dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSales"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Soft top-edge fade: content dissolves into the card top while
             scrolling (no hard line). Sits over the scroll, not touchable. -->
        <View
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_gravity="top"
            android:background="@drawable/bg_scroll_top_fade"/>

        </FrameLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
