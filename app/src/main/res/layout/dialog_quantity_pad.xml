<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardUseCompatPadding="false"
    app:cardBackgroundColor="#FBF9F4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADD QUANTITY"
                    android:textColor="#B8895A"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:fontFamily="@font/googlesans_semibold"/>

                <TextView
                    android:id="@+id/tvProductName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="Product"
                    android:textColor="#1A1A18"
                    android:textSize="16sp"
                    android:fontFamily="@font/googlesans_bold"
                    android:singleLine="true"
                    android:ellipsize="end"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/btnCloseQty"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:padding="6dp"
                android:src="@drawable/ic_dialog_close"
                app:tint="#9A968C"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"/>
        </LinearLayout>

        <!-- Navy receipt display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_qty_display_navy"
            android:padding="16dp"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#9FB0D4"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ×  "
                    android:textColor="#9FB0D4"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvUnitPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="#9FB0D4"
                    android:textSize="14sp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="#2A3A63"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:id="@+id/tvLineTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:fontFamily="@font/googlesans_bold"
                    android:includeFontPadding="false"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_marginBottom="3dp"
                    android:text="total"
                    android:textColor="#D4A574"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Keypad -->
        <GridLayout
            android:id="@+id/gridPad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="4"
            android:useDefaultMargins="true"
            android:alignmentMode="alignMargins"
            android:layout_marginTop="12dp">

            <com.google.android.material.button.MaterialButton style="@style/PosKeyLight" android:text="1"/>
            <com.google.android.material.button.MaterialButton style="@style/PosKeyLight" android:text="2"/>
            <com.google.android.material.button.MaterialButton style="@style/PosKeyLight" android:text="3"/>

            <com.google.android.material.button.MaterialButton style="@style/PosKeyLight" android:text="4"/>
            <com.google.android.material.button.MaterialButton style="@style/PosKeyLight" android:text="5"/>
            <com.google.android.material.button.MaterialButton style="@style/PosKeyLight" android:text="6"/>

            <com.google.android.material.button.MaterialButton style="@style/PosKeyLight" android:text="7"/>
            <com.google.android.material.button.MaterialButton style="@style/PosKeyLight" android:text="8"/>
            <com.google.android.material.button.MaterialButton style="@style/PosKeyLight" android:text="9"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDot"
                style="@style/PosKeyLight"
                android:textColor="#8A5A2B"
                android:text="."/>

            <com.google.android.material.button.MaterialButton style="@style/PosKeyLight" android:text="0"/>

            <ImageButton
                android:id="@+id/btnBackspace"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_qty_key_red"
                android:src="@drawable/ic_qty_backspace"
                app:tint="#B91C1C"
                android:scaleType="centerInside"
                android:padding="14dp"
                android:contentDescription="Backspace"/>
        </GridLayout>

        <!-- Add to cart -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddQty"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Add to cart"
            android:textSize="15sp"
            android:textColor="@android:color/white"
            android:fontFamily="@font/googlesans_semibold"
            android:layout_marginTop="14dp"
            app:cornerRadius="14dp"
            app:backgroundTint="#0F6E56"
            app:icon="@drawable/ic_drawer_purchase"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@android:color/white"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
