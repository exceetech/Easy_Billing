<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="60dp"

    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardUseCompatPadding="false"
    app:cardBackgroundColor="#0F172A">

<LinearLayout
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:orientation="vertical"
android:padding="18dp">

<!-- DISPLAY (TALLER) -->

    <!-- BACKSPACE -->

    <!-- KEYPAD (TALLER BUTTONS) -->
    <TextView
        android:id="@+id/tvQuantity"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#1E293B"
        android:gravity="end|center_vertical"
        android:paddingHorizontal="14dp"
        android:text="0"
        android:textColor="#F8FAFC"
        android:textSize="38sp"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/btnBackspace"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="end"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_input_delete"
        app:tint="#EF4444" />

    <GridLayout
    android:id="@+id/gridPad"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:columnCount="3"
    android:rowCount="4"
    android:useDefaultMargins="true"
    android:alignmentMode="alignMargins">

    <com.google.android.material.button.MaterialButton style="@style/PosKeyTall" android:text="1"/>
    <com.google.android.material.button.MaterialButton style="@style/PosKeyTall" android:text="2"/>
    <com.google.android.material.button.MaterialButton style="@style/PosKeyTall" android:text="3"/>

    <com.google.android.material.button.MaterialButton style="@style/PosKeyTall" android:text="4"/>
    <com.google.android.material.button.MaterialButton style="@style/PosKeyTall" android:text="5"/>
    <com.google.android.material.button.MaterialButton style="@style/PosKeyTall" android:text="6"/>

    <com.google.android.material.button.MaterialButton style="@style/PosKeyTall" android:text="7"/>
    <com.google.android.material.button.MaterialButton style="@style/PosKeyTall" android:text="8"/>
    <com.google.android.material.button.MaterialButton style="@style/PosKeyTall" android:text="9"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDot"
        style="@style/PosKeyTall"
        android:text="."/>

    <com.google.android.material.button.MaterialButton style="@style/PosKeyTall" android:text="0"/>

    <com.google.android.material.button.MaterialButton
        style="@style/PosKeyClearTall"
        android:text="C"/>

</GridLayout>

<!-- ADD BUTTON (BIGGER) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddQty"
        android:layout_width="match_parent"
        android:layout_height="56dp"

        android:text="Add to Cart"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="@android:color/white"

        android:layout_marginTop="16dp"

        app:cornerRadius="14dp"
        app:backgroundTint="#22C55E"

        app:icon="@drawable/ic_cart"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconTint="@android:color/white"/>

</LinearLayout>

    </com.google.android.material.card.MaterialCardView>