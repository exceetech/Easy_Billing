<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_champagne"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <!-- Toolbar (same as inventory: transparent, back nav via BaseActivity) -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        android:elevation="0dp"
        app:title=""
        app:titleTextColor="#1A1A18"
        app:navigationIconTint="#1A1A18"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Sign-up-style frosted card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/monolithCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="36dp"
        android:layout_marginVertical="22dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#94FFFFFF"
        app:strokeColor="#CCFFFFFF"
        app:strokeWidth="1dp"
        app:layout_constraintWidth_max="660dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:animateLayoutChanges="true"
            android:paddingHorizontal="26dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <!-- Key badge -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/headerIconCard"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_success_circle">
                    <ImageView
                        android:layout_width="27dp"
                        android:layout_height="27dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_reset_lock"
                        app:tint="#0F6E56"
                        android:contentDescription="@null"/>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Eyebrow -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="ACCOUNT RECOVERY"
                android:textColor="#B8895A"
                android:textSize="10sp"
                android:letterSpacing="0.16"
                android:fontFamily="@font/googlesans_semibold"/>

            <!-- Title -->
            <TextView
                android:id="@+id/headerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Forgot password?"
                android:textColor="#1A1A18"
                android:textSize="22sp"
                android:fontFamily="serif"
                android:textStyle="bold"/>

            <!-- Subtitle -->
            <TextView
                android:id="@+id/headerSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:gravity="center"
                android:text="Enter your registered email and we'll send a verification code."
                android:textColor="#6E6A60"
                android:textSize="12.5sp"
                android:lineSpacingExtra="2dp"/>

            <!-- Email section -->
            <LinearLayout
                android:id="@+id/emailSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp">

                <TextView
                    android:id="@+id/lblEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#6E6A60"
                    android:textSize="11.5sp"
                    android:fontFamily="@font/googlesans_semibold"
                    android:layout_marginBottom="6dp"/>

                <FrameLayout
                    android:id="@+id/emailContainer"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_password_input">
                    <ImageView
                        android:id="@+id/iconEmail"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="13dp"
                        android:src="@drawable/ic_lc_mail"
                        app:tint="#B8895A"
                        android:contentDescription="@null"/>
                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:paddingStart="42dp"
                        android:paddingEnd="16dp"
                        android:hint="Enter email"
                        android:textColor="#1A1A18"
                        android:textColorHint="#A99E88"
                        android:inputType="textEmailAddress"
                        android:textCursorDrawable="@drawable/cursor_thin"
                        android:textSize="15sp"/>
                </FrameLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_login_cta_green"
                    app:backgroundTint="@null"
                    android:text="Send reset code"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:fontFamily="@font/googlesans_semibold"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_cta_arrow"
                    app:iconGravity="textEnd"
                    app:iconTint="#FFFFFF"/>
            </LinearLayout>

            <!-- OTP section (revealed inline after sending) -->
            <LinearLayout
                android:id="@+id/otpLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="gone"
                android:layout_marginTop="18dp">

                <!-- Dashed separator -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layerType="software"
                    android:background="@drawable/bg_dashed_line"/>

                <!-- Label + Sent chip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="18dp">
                    <TextView
                        android:id="@+id/lblOtp"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Verification code"
                        android:textColor="#6E6A60"
                        android:textSize="11.5sp"
                        android:fontFamily="@font/googlesans_semibold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sent"
                        android:textColor="#1D9E75"
                        android:textSize="10sp"
                        android:fontFamily="@font/googlesans_semibold"
                        android:background="@drawable/bg_success_circle"
                        android:paddingHorizontal="9dp"
                        android:paddingVertical="2dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvOtpSentTo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Enter the 6-digit code we emailed you"
                    android:textColor="#A99E88"
                    android:textSize="11sp"/>

                <!-- 6 circular boxes -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <EditText android:id="@+id/otpBox1"
                        android:layout_width="36dp" android:layout_height="36dp" android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_otp_box" android:gravity="center" android:padding="0dp"
                        android:includeFontPadding="false" android:inputType="number" android:maxLength="1"
                        android:textSize="18sp" android:textColor="#1A1A18" android:textCursorDrawable="@drawable/cursor_thin"
                        android:fontFamily="@font/googlesans_semibold" android:importantForAutofill="no"
                        android:contentDescription="OTP digit 1"/>
                    <EditText android:id="@+id/otpBox2"
                        android:layout_width="36dp" android:layout_height="36dp" android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_otp_box" android:gravity="center" android:padding="0dp"
                        android:includeFontPadding="false" android:inputType="number" android:maxLength="1"
                        android:textSize="18sp" android:textColor="#1A1A18" android:textCursorDrawable="@drawable/cursor_thin"
                        android:fontFamily="@font/googlesans_semibold" android:importantForAutofill="no"
                        android:contentDescription="OTP digit 2"/>
                    <EditText android:id="@+id/otpBox3"
                        android:layout_width="36dp" android:layout_height="36dp" android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_otp_box" android:gravity="center" android:padding="0dp"
                        android:includeFontPadding="false" android:inputType="number" android:maxLength="1"
                        android:textSize="18sp" android:textColor="#1A1A18" android:textCursorDrawable="@drawable/cursor_thin"
                        android:fontFamily="@font/googlesans_semibold" android:importantForAutofill="no"
                        android:contentDescription="OTP digit 3"/>
                    <EditText android:id="@+id/otpBox4"
                        android:layout_width="36dp" android:layout_height="36dp" android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_otp_box" android:gravity="center" android:padding="0dp"
                        android:includeFontPadding="false" android:inputType="number" android:maxLength="1"
                        android:textSize="18sp" android:textColor="#1A1A18" android:textCursorDrawable="@drawable/cursor_thin"
                        android:fontFamily="@font/googlesans_semibold" android:importantForAutofill="no"
                        android:contentDescription="OTP digit 4"/>
                    <EditText android:id="@+id/otpBox5"
                        android:layout_width="36dp" android:layout_height="36dp" android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_otp_box" android:gravity="center" android:padding="0dp"
                        android:includeFontPadding="false" android:inputType="number" android:maxLength="1"
                        android:textSize="18sp" android:textColor="#1A1A18" android:textCursorDrawable="@drawable/cursor_thin"
                        android:fontFamily="@font/googlesans_semibold" android:importantForAutofill="no"
                        android:contentDescription="OTP digit 5"/>
                    <EditText android:id="@+id/otpBox6"
                        android:layout_width="36dp" android:layout_height="36dp" android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_otp_box" android:gravity="center" android:padding="0dp"
                        android:includeFontPadding="false" android:inputType="number" android:maxLength="1"
                        android:textSize="18sp" android:textColor="#1A1A18" android:textCursorDrawable="@drawable/cursor_thin"
                        android:fontFamily="@font/googlesans_semibold" android:importantForAutofill="no"
                        android:contentDescription="OTP digit 6"/>
                </LinearLayout>

                <!-- Hidden aggregate field consumed by verify logic -->
                <EditText
                    android:id="@+id/etOtp"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:visibility="invisible"
                    android:inputType="number"
                    android:maxLength="6"
                    android:importantForAutofill="no"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerifyOtp"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_login_cta_green"
                    app:backgroundTint="@null"
                    android:text="Verify code"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:fontFamily="@font/googlesans_semibold"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_cta_arrow"
                    app:iconGravity="textEnd"
                    app:iconTint="#FFFFFF"/>
            </LinearLayout>

            <!-- Footer -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remembered it? "
                    android:textColor="#6E6A60"
                    android:textSize="12.5sp"/>
                <TextView
                    android:id="@+id/tvBackToLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Back to login"
                    android:textColor="#0F6E56"
                    android:textSize="12.5sp"
                    android:fontFamily="@font/googlesans_semibold"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
