<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <!-- GUIDELINE -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineCenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.55" />

    <!-- ======================= -->
    <!-- MAIN CONTAINER CARD -->
    <!-- ======================= -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mainContainerCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="32dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeWidth="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Split Guideline -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/cardGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.55" />



        <!-- RIGHT PANE: LOGIN FORM (Now inside the card) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/loginContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:paddingHorizontal="60dp"
            android:paddingVertical="48dp"
            app:layout_constraintStart_toEndOf="@id/cardGuideline"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Welcome Text -->
            <LinearLayout
                android:id="@+id/loginHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/loginForm"
                app:layout_constraintVertical_chainStyle="packed">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome Back! 👋"
                    android:textSize="34sp"
                    android:textColor="#0F172A"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Login to continue to your account\nand manage your business."
                    android:textSize="16sp"
                    android:textColor="#64748B"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>

            <!-- Form Fields -->
            <LinearLayout
                android:id="@+id/loginForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="60dp"
                app:layout_constraintTop_toBottomOf="@id/loginHeader"
                app:layout_constraintBottom_toTopOf="@id/loginFooter">

                <TextView
                    android:id="@+id/lblEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textSize="14sp"
                    android:textColor="#334155"
                    android:layout_marginBottom="8dp"
                    android:textStyle="bold"/>

                <FrameLayout
                    android:id="@+id/usernameContainer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_premium_input">
                    <ImageView
                        android:id="@+id/iconUsername"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_mail"
                        app:tint="#94A3B8"/>
                    <EditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:paddingStart="48dp"
                        android:paddingEnd="16dp"
                        android:hint="Enter your email"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:inputType="textEmailAddress"
                        android:singleLine="true"
                        android:textSize="15sp" />
                </FrameLayout>

                <TextView
                    android:id="@+id/lblPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textSize="14sp"
                    android:textColor="#334155"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"/>

                <FrameLayout
                    android:id="@+id/passwordContainer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_premium_input">
                    <ImageView
                        android:id="@+id/iconPassword"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_lock"
                        app:tint="#94A3B8"/>
                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:paddingStart="48dp"
                        android:paddingEnd="48dp"
                        android:hint="Enter your password"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:inputType="textPassword"
                        android:singleLine="true"
                        android:textSize="15sp" />
                    <!-- Password visibility toggle -->
                    <ImageView
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_visibility_off"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="#94A3B8"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="12dp"
                    android:text="Forgot Password?"
                    android:textColor="#4F46E5"
                    android:textSize="14sp"

                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_login_btn_gradient"
                    app:backgroundTint="@null"
                    android:text="Login"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_arrow_forward"
                    app:iconGravity="textEnd"
                    app:iconTint="#FFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="32dp">
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#000000"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="or"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:layout_marginHorizontal="16dp" />
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#000000"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Don't have an account? "
                        android:textColor="#64748B"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tvRegister"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign Up"
                        android:textColor="#4F46E5"
                        android:textSize="14sp"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Security Footer -->
            <LinearLayout
                android:id="@+id/loginFooter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="40dp"
                app:layout_constraintTop_toBottomOf="@id/loginForm"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent">
                
                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_security_login"
                    android:background="@drawable/bg_soft_circle"
                    android:padding="10dp"
                    app:tint="#8A5CF5"/>
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your data is 100% secure and protected with enterprise grade security."
                    android:textColor="#94A3B8"
                    android:textSize="15sp"
                    android:layout_marginStart="12dp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- LEFT PANE: BRANDING (Material Card for rounded corners) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/brandingPane"
                android:transitionName="shared_branding_pane"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                app:cardCornerRadius="20dp"
                app:cardElevation="25dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/cardGuideline">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                <ImageView
                    android:id="@+id/imgIllustration"
                    android:transitionName="shared_image_pane"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/img_login1"
                    android:scaleType="centerCrop" />

                <!-- Top Scrim for Readability: Blends the image top with the layout -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:background="@drawable/bg_top_scrim"/>

                    <LinearLayout
                        android:id="@+id/brandingContent"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:orientation="vertical"
                        android:paddingHorizontal="36dp"
                        android:paddingTop="36dp"
                        android:paddingBottom="12dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="32dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/brandLogo"
                                android:layout_width="52dp"
                                android:layout_height="52dp" />

                            <LinearLayout
                                android:id="@+id/brandTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Ex"
                                        android:textColor="#0F172A"
                                        android:textSize="42sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="POS"
                                        android:textColor="#6366F1"
                                        android:textSize="42sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:letterSpacing="0.02"
                                    android:text="Retail  •  Restaurant  •  Bakery  •  Grocery"
                                    android:textColor="#3E607C"
                                    android:textSize="14sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/brandTagline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="4dp"
                            android:text="Manage sales, inventory, billing\nand grow your business."
                            android:textColor="#3E607C"
                            android:textSize="16sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/brandFeatures"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="24dp"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:baselineAligned="false"
                                    android:gravity="center"
                                    android:orientation="horizontal"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="14dp">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <FrameLayout
                                            android:layout_width="60dp"
                                            android:layout_height="60dp"
                                            android:background="@drawable/bg_circle_primary">

                                            <ImageView
                                                android:layout_width="40dp"
                                                android:layout_height="40dp"
                                                android:layout_gravity="center"
                                                android:src="@drawable/ic_bill_login"
                                                app:tint="#FFFFFF" />
                                        </FrameLayout>

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="6dp"
                                            android:gravity="center"
                                            android:text="Easy\nBilling"
                                            android:textColor="#3E607C"
                                            android:textSize="14sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <FrameLayout
                                            android:layout_width="60dp"
                                            android:layout_height="60dp"
                                            android:background="@drawable/bg_circle_orange">

                                            <ImageView
                                                android:layout_width="40dp"
                                                android:layout_height="40dp"
                                                android:layout_gravity="center"
                                                android:src="@drawable/ic_inventory_login"
                                                app:tint="#FFFFFF" />
                                        </FrameLayout>

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="6dp"
                                            android:gravity="center"
                                            android:text="Inventory\nManagement"
                                            android:textColor="#3E607C"
                                            android:textSize="14sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <FrameLayout
                                            android:layout_width="60dp"
                                            android:layout_height="60dp"
                                            android:background="@drawable/bg_circle_green">

                                            <ImageView
                                                android:layout_width="40dp"
                                                android:layout_height="40dp"
                                                android:layout_gravity="center"
                                                android:src="@drawable/ic_graph_login"
                                                app:tint="#FFFFFF" />
                                        </FrameLayout>

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="6dp"
                                            android:gravity="center"
                                            android:text="Sales\nAnalytics"
                                            android:textColor="#3E607C"
                                            android:textSize="14sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <FrameLayout
                                            android:layout_width="60dp"
                                            android:layout_height="60dp"
                                            android:background="@drawable/bg_circle_pink">

                                            <ImageView
                                                android:layout_width="40dp"
                                                android:layout_height="40dp"
                                                android:layout_gravity="center"
                                                android:src="@drawable/ic_shop_login"
                                                app:tint="#FFFFFF" />
                                        </FrameLayout>

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="6dp"
                                            android:gravity="center"
                                            android:text="Multi-Store\nSupport"
                                            android:textColor="#3E607C"
                                            android:textSize="14sp" />
                                    </LinearLayout>
                                </LinearLayout>
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
